<Window x:Class="ScumScriptStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scum Script Studio" Height="900" Width="1450" MinHeight="760" MinWidth="1180">
    <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="330"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0" Padding="10">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="SCUM SCRIPT STUDIO" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Accent}" Margin="4,4,4,12"/>
                    <WrapPanel><Button Content="Ordner öffnen" Click="OpenFolder_Click"/><Button Content="Neu" Click="NewScript_Click"/><Button Content="Neu laden" Click="Reload_Click"/></WrapPanel>
                    <TextBlock x:Name="FolderText" Text="Kein Ordner gewählt" Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="6,6,6,10"/>
                    <TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged" ToolTip="Skripte filtern" />
                </StackPanel>
                <ListBox x:Name="ScriptList" SelectionChanged="ScriptList_SelectionChanged" DisplayMemberPath="DisplayName"/>
            </DockPanel>
        </Border>
        <DockPanel Grid.Column="1" Background="{StaticResource Bg}">
            <Border DockPanel.Dock="Top" Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="8">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"><Button Content="Validieren" Click="Validate_Click"/><Button Content="Formatieren" Click="FormatJson_Click"/><Button Content="Speichern" Click="Save_Click"/><Button Content="Speichern als..." Click="SaveAs_Click"/></StackPanel>
                    <StackPanel><TextBlock x:Name="TitleText" Text="Kein Skript geladen" FontSize="20" FontWeight="Bold"/><TextBlock x:Name="FileText" Text="" Foreground="{StaticResource Muted}"/></StackPanel>
                </DockPanel>
            </Border>
            <Grid><Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="180"/></Grid.RowDefinitions>
                <TabControl Grid.Row="0" x:Name="EditorTabs" Margin="8" Background="{StaticResource Bg}">
                    <TabItem Header="Simple Mode">
                        <Grid Margin="12" Background="{StaticResource Bg}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Simple Mode" FontSize="22" FontWeight="Bold"/>
                                <TextBlock Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,4,0,12"
                                           Text="Hier baust du ein Event nur aus Name, NPC-/Puppet-Spawns, Loot-Spots und Lootpacks. Aktivierungszone, Cleanup und Lootpacks werden automatisch erzeugt."/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Event-ID" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="SimpleIdBox"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Name" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="0" Grid.Column="3" x:Name="SimpleNameBox"/>
                                    <TextBlock Grid.Row="0" Grid.Column="4" Text="Mode" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="0" Grid.Column="5" x:Name="SimpleModeBox">
                                        <ComboBoxItem Content="SilentZone"/>
                                        <ComboBoxItem Content="RandomAnnouncedZone"/>
                                    </ComboBox>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Cooldown Min." VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="SimpleCooldownBox" Text="180"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Cleanup leer Sek." VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="3" x:Name="SimpleCleanupEmptyBox" Text="300"/>
                                    <TextBlock Grid.Row="1" Grid.Column="4" Text="Extra Radius" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="5" x:Name="SimpleExtraRadiusBox" Text="10000"/>
                                </Grid>
                            </StackPanel>

                            <Grid Grid.Row="1" Margin="0,14,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                                        <TextBlock Text="NPC-Spawns" FontSize="17" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <Button Content="+ NPC" Click="SimpleAddNpc_Click"/>
                                        <Button Content="- NPC" Click="SimpleRemoveNpc_Click"/>
                                    </StackPanel>
                                    <DataGrid x:Name="SimpleNpcGrid" ItemsSource="{Binding SimpleNpcs}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="150"/>
                                            <DataGridTemplateColumn Header="Spawn" Width="120">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding SpawnType}" VerticalAlignment="Center"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                                <DataGridTemplateColumn.CellEditingTemplate>
                                                    <DataTemplate>
                                                        <ComboBox ItemsSource="{Binding DataContext.SpawnTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  SelectedItem="{Binding SpawnType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellEditingTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="NPC Type" Binding="{Binding NpcType}" Width="160"/>
                                            <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="60"/>
                                            <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>

                                <DockPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,8">
                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                                        <TextBlock Text="Loot-Spots" FontSize="17" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <Button Content="+ Spot" Click="SimpleAddLootSpot_Click"/>
                                        <Button Content="- Spot" Click="SimpleRemoveLootSpot_Click"/>
                                    </StackPanel>
                                    <DataGrid x:Name="SimpleLootSpotGrid" ItemsSource="{Binding SimpleLootSpots}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="170"/>
                                            <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>

                                <DockPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,0">
                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                                        <TextBlock Text="Lootpacks" FontSize="17" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <Button Content="+ Pack" Click="SimpleAddLootPack_Click"/>
                                        <Button Content="- Pack" Click="SimpleRemoveLootPack_Click"/>
                                        <Button Content="+ Item" Click="SimpleAddLootItem_Click"/>
                                        <Button Content="- Item" Click="SimpleRemoveLootItem_Click"/>
                                        <Button Content="Beispielpacks einfügen" Click="SimpleInsertExamplePacks_Click"/>
                                    </StackPanel>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="360"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <DataGrid Grid.Column="0" x:Name="SimpleLootPackGrid"
                                                  ItemsSource="{Binding SimpleLootPacks}"
                                                  SelectionChanged="SimpleLootPackGrid_SelectionChanged"
                                                  Margin="0,0,8,0">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                                                <DataGridTextColumn Header="Gewicht" Binding="{Binding Weight}" Width="80"/>
                                                <DataGridCheckBoxColumn Header="Aktiv" Binding="{Binding Enabled}" Width="60"/>
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <DataGrid Grid.Column="1" x:Name="SimpleLootItemGrid"
                                                  ItemsSource="{Binding SimpleSelectedLootItems}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Item" Binding="{Binding Item}" Width="*"/>
                                                <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="100"/>
                                                <DataGridTextColumn Header="DelayMs" Binding="{Binding DelayMs}" Width="100"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </DockPanel>
                            </Grid>

                            <Border Grid.Row="2" Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8" Padding="10">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button Content="Aus aktuellem JSON laden" Click="SimpleLoadFromJson_Click"/>
                                        <Button Content="Event automatisch bauen" Click="SimpleBuildJson_Click"/>
                                    </StackPanel>
                                    <TextBlock Text="Automatisch: ActivationZone aus allen NPC- und Loot-Locations, Cleanup aus Loot-Spots, Lootpacks an jedem Loot-Spot." VerticalAlignment="Center" Foreground="{StaticResource Muted}"/>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Basis"><ScrollViewer><StackPanel Margin="14">
                        <TextBlock Text="Grunddaten" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="ID" VerticalAlignment="Center"/><TextBox Grid.Row="0" Grid.Column="1" x:Name="IdBox"/><TextBlock Grid.Row="0" Grid.Column="2" Text="Name" VerticalAlignment="Center"/><TextBox Grid.Row="0" Grid.Column="3" x:Name="NameBox"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Mode" VerticalAlignment="Center"/><ComboBox Grid.Row="1" Grid.Column="1" x:Name="ModeBox"><ComboBoxItem Content="SilentZone"/><ComboBoxItem Content="RandomAnnouncedZone"/><ComboBoxItem Content="DirectLive"/></ComboBox><TextBlock Grid.Row="1" Grid.Column="2" Text="Announcement Type" VerticalAlignment="Center"/><ComboBox Grid.Row="1" Grid.Column="3" x:Name="AnnouncementTypeBox"><ComboBoxItem Content="Yellow"/><ComboBoxItem Content="White"/><ComboBoxItem Content="Cyan"/><ComboBoxItem Content="Green"/><ComboBoxItem Content="Red"/><ComboBoxItem Content="ServerMessage"/><ComboBoxItem Content="Error"/></ComboBox>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Announcement" VerticalAlignment="Center"/><TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" x:Name="AnnouncementBox"/>
                            <CheckBox Grid.Row="3" Grid.Column="1" x:Name="EnabledBox" Content="Aktiviert"/><CheckBox Grid.Row="3" Grid.Column="3" x:Name="IncludeRandomizerBox" Content="In Randomizer aufnehmen"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="EventGroup" VerticalAlignment="Center"/><TextBox Grid.Row="4" Grid.Column="1" x:Name="EventGroupBox"/><TextBlock Grid.Row="4" Grid.Column="2" Text="Max Concurrent In Group" VerticalAlignment="Center"/><TextBox Grid.Row="4" Grid.Column="3" x:Name="MaxConcurrentInGroupBox"/>
                        </Grid><Separator Margin="0,20"/>
                        <TextBlock Text="Zeiten" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Cooldown Minuten"/><TextBox Grid.Row="0" Grid.Column="1" x:Name="CooldownBox"/><TextBlock Grid.Row="0" Grid.Column="2" Text="Cleanup wenn leer Sekunden"/><TextBox Grid.Row="0" Grid.Column="3" x:Name="CleanupEmptyBox"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Randomizer alle Minuten"/><TextBox Grid.Row="1" Grid.Column="1" x:Name="RandomizerEveryBox"/><TextBlock Grid.Row="1" Grid.Column="2" Text="Initiator Repeat Minuten"/><TextBox Grid.Row="1" Grid.Column="3" x:Name="InitiatorRepeatBox"/>
                        </Grid><Separator Margin="0,20"/>
                        <TextBlock Text="Aktivierungszone" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name"/><TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="7" x:Name="ZoneNameBox"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Center X"/><TextBox Grid.Row="1" Grid.Column="1" x:Name="ZoneXBox"/><TextBlock Grid.Row="1" Grid.Column="2" Text="Y"/><TextBox Grid.Row="1" Grid.Column="3" x:Name="ZoneYBox"/><TextBlock Grid.Row="1" Grid.Column="4" Text="Z"/><TextBox Grid.Row="1" Grid.Column="5" x:Name="ZoneZBox"/><TextBlock Grid.Row="1" Grid.Column="6" Text="Radius"/><TextBox Grid.Row="1" Grid.Column="7" x:Name="ZoneRadiusBox"/>
                        </Grid><WrapPanel Margin="0,16,0,0"><Button Content="Formular ins JSON übernehmen" Click="ApplyBasics_Click"/><Button Content="Legacy zone → activationZone" Click="ConvertLegacyZone_Click"/></WrapPanel>
                    </StackPanel></ScrollViewer></TabItem>
                    <TabItem Header="Command-Blöcke"><Grid Margin="12"><Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <ListBox x:Name="BlockList" SelectionChanged="BlockList_SelectionChanged"><ListBoxItem Content="initiatorBlock"/><ListBoxItem Content="preLiveCleanupBlock"/><ListBoxItem Content="liveBlock"/><ListBoxItem Content="emptyBlock"/><ListBoxItem Content="cleanupBlock"/></ListBox>
                        <DockPanel Grid.Column="1" Margin="10,0,0,0"><StackPanel DockPanel.Dock="Top" Orientation="Horizontal"><Button Content="Block aus JSON laden" Click="LoadBlock_Click"/><Button Content="Block ins JSON übernehmen" Click="ApplyBlock_Click"/><Button Content="+ Command" Click="AddCommand_Click"/><Button Content="- Command" Click="RemoveCommand_Click"/></StackPanel>
                            <DataGrid x:Name="CommandsGrid" ItemsSource="{Binding Commands}" Margin="0,8,0,0"><DataGrid.Columns><DataGridCheckBoxColumn Header="Enabled" Binding="{Binding Enabled}" Width="70"/><DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="220"/><DataGridTextColumn Header="Command" Binding="{Binding Command}" Width="*"/><DataGridTextColumn Header="Repeat" Binding="{Binding Repeat}" Width="70"/><DataGridTextColumn Header="DelayMs" Binding="{Binding DelayMs}" Width="80"/></DataGrid.Columns></DataGrid>
                        </DockPanel></Grid></TabItem>
                    <TabItem Header="Lootpacks">
                        <Grid Margin="12" Background="{StaticResource Bg}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="360"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <DockPanel Grid.Column="0">
                                <StackPanel DockPanel.Dock="Top">
                                    <TextBlock Text="Lootpacks" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,4,0,8"
                                               Text="Jeder Pack wird als normaler lootPack mit Location und Items gespeichert. Gewicht steuert die Zufallsauswahl."/>
                                    <WrapPanel>
                                        <Button Content="Aus JSON laden" Click="LoadLootEditor_Click"/>
                                        <Button Content="+ Pack" Click="AddLootPack_Click"/>
                                        <Button Content="- Pack" Click="RemoveLootPack_Click"/>
                                    </WrapPanel>
                                </StackPanel>

                                <ListBox x:Name="LootPackList"
                                         ItemsSource="{Binding LootPacks}"
                                         DisplayMemberPath="DisplayName"
                                         SelectionChanged="LootPackList_SelectionChanged"
                                         Margin="0,8,8,0"/>
                            </DockPanel>

                            <DockPanel Grid.Column="1" Margin="10,0,0,0">
                                <StackPanel DockPanel.Dock="Top">
                                    <TextBlock Text="Pack bearbeiten" FontSize="18" FontWeight="Bold"/>
                                    <Grid Margin="0,8,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="180"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="LootNameBox" TextChanged="LootPackField_TextChanged"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Gewicht" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="0" Grid.Column="3" x:Name="LootWeightBox" TextChanged="LootPackField_TextChanged"/>
                                        <CheckBox Grid.Row="0" Grid.Column="5" x:Name="LootEnabledBox" Content="Aktiv" Checked="LootPackField_Checked" Unchecked="LootPackField_Checked"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Hinweis" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="Kistenmodus entfernt" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="DelayMs" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="1" Grid.Column="3" x:Name="LootDelayBox" TextChanged="LootPackField_TextChanged"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Location" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="5" x:Name="LootLocationBox" TextChanged="LootPackField_TextChanged"/>
                                    </Grid>

                                    <WrapPanel Margin="0,0,0,8">
                                        <Button Content="+ Item" Click="AddLootItem_Click"/>
                                        <Button Content="- Item" Click="RemoveLootItem_Click"/>
                                        <Button Content="Pack duplizieren" Click="DuplicateLootPack_Click"/>
                                        <Button Content="Loot Vorschau aktualisieren" Click="RefreshLootCommandPreview_Click"/>
                                        <Button Content="Lootpacks ins JSON übernehmen" Click="ApplyLootEditor_Click"/>
                                    </WrapPanel>
                                </StackPanel>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="150"/>
                                    </Grid.RowDefinitions>

                                    <DataGrid Grid.Row="0" x:Name="LootItemsGrid"
                                              ItemsSource="{Binding SelectedLootItems}"
                                              Margin="0,0,0,8">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Item" Binding="{Binding Item}" Width="*"/>
                                            <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="100"/>
                                            <DataGridTextColumn Header="DelayMs" Binding="{Binding DelayMs}" Width="100"/>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <DockPanel Grid.Row="1">
                                        <TextBlock DockPanel.Dock="Top" Text="Lootpack-Vorschau" FontWeight="Bold" Margin="0,0,0,4"/>
                                        <TextBox x:Name="LootCommandPreviewBox"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 FontFamily="Consolas"
                                                 FontSize="12"/>
                                    </DockPanel>
                                </Grid>
                            </DockPanel>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Raw JSON"><DockPanel Margin="12"><TextBlock DockPanel.Dock="Top" Foreground="{StaticResource Muted}" Margin="0,0,0,8" Text="Raw JSON bleibt immer die Quelle. Formularänderungen müssen mit den jeweiligen Übernehmen-Buttons ins JSON geschrieben werden."/><TextBox x:Name="RawJsonBox" AcceptsReturn="True" AcceptsTab="True" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="13"/></DockPanel></TabItem>
                </TabControl>
                <Border Grid.Row="1" Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="1,1,0,0" Padding="8"><DockPanel><TextBlock DockPanel.Dock="Top" Text="Validierung / Log" FontSize="16" FontWeight="Bold"/><TextBox x:Name="LogBox" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Background="#0d0d11" Foreground="#e8e8e8"/></DockPanel></Border>
            </Grid>
        </DockPanel>
    </Grid>
</Window>
