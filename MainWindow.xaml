                                    <TextBlock Text="Remote Directory" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.FtpRemoteDirectory, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Chatlog Pattern" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.FtpChatLogPattern, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Vehicle-Destruction Log Pattern" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.FtpVehicleDestructionLogPattern, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Loginlog Pattern" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.FtpLoginLogPattern, UpdateSourceTrigger=PropertyChanged}" />
                                    <CheckBox Content="{Binding Texts[ScriptsAutoStart]}" IsChecked="{Binding Settings.AutoStartScripts}" />
                                    <CheckBox Content="{Binding Texts[ChatlogsAutoStart]}" IsChecked="{Binding Settings.AutoStartDiscordChatLogs}" />
                                    <CheckBox Content="{Binding Texts[DiscordServerStatusAutoUpdate]}" IsChecked="{Binding Settings.AutoStartDiscordServerStatusMessage}" />
                                    <CheckBox Content="{Binding Texts[DiscordBotStatusAutoUpdate]}" IsChecked="{Binding Settings.AutoStartDiscordBotStatus}" />
                                    <CheckBox Content="{Binding Texts[CheckUpdatesOnStart]}" IsChecked="{Binding Settings.AutoCheckForUpdates}" />
                                    <CheckBox Content="{Binding Texts[UsageDirectoryOptIn]}" IsChecked="{Binding Settings.UsageDirectoryEnabled}" Margin="0,10,0,0" />
                                    <TextBlock Text="{Binding Texts[UsageDirectoryDescription]}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                                    <Button Content="{Binding Texts[UsageDirectoryOpenSource]}" Command="{Binding OpenUsageDirectorySourceCommand}" HorizontalAlignment="Left" Margin="0,6,0,0" />
                                    <TextBlock Text="{Binding UsageDirectoryStatus}" Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Texts[UsageDirectoryApi]}" Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0" />
                                    <TextBox Text="{Binding Settings.UsageDirectoryEndpointUrl, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Update latest.json URL" Foreground="{StaticResource MutedTextBrush}" Margin="0,10,0,0" />
                                    <TextBox Text="{Binding Settings.UpdateLatestJsonUrl, UpdateSourceTrigger=PropertyChanged}" />
                                    <CheckBox Content="{Binding Texts[ChatAutoStart]}" IsChecked="{Binding Settings.AutoStartChatCommands}" />
                                    <CheckBox Content="{Binding Texts[PaidVotes]}" IsChecked="{Binding Settings.PaidVotesEnabled}" />
                                    <TextBlock Text="{Binding Texts[VotePrice]}" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.VotePrice, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{Binding Texts[VoteConfirmationSeconds]}" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.VoteConfirmationTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{Binding Texts[VotePrompt]}" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.VotePurchasePromptResponse, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Texts[VoteInsufficientFunds]}" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.VoteInsufficientFundsResponse, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />
                                    <CheckBox Content="{Binding Texts[JoinAutoStart]}" IsChecked="{Binding Settings.AutoStartJoinCommands}" />
                                    <CheckBox Content="{Binding Texts[KillFeedAutoStart]}" IsChecked="{Binding Settings.AutoStartKillFeed}" />
                                    <CheckBox Content="{Binding Texts[WeeklyAutoStart]}" IsChecked="{Binding Settings.AutoStartWeeklyTasks}" />
                                    <TextBlock Text="{Binding Texts[WeeklyDbPath]}" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.WeeklyTaskDbRemoteFilePath, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{Binding Texts[WeeklyPollMinutes]}" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.WeeklyTaskPollMinutes, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Killlog Pattern" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.FtpKillLogPattern, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{Binding Texts[KillfeedPollSeconds]}" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.KillPollSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{Binding Texts[IngameMessageColor]}" Foreground="{StaticResource MutedTextBrush}" />
                                    <ComboBox ItemsSource="{Binding BroadcastMessageTypes}" SelectedItem="{Binding Settings.KillAnnounceColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{Binding Texts[ScriptPollSeconds]}" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.ScriptPollSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                    <CheckBox Content="{Binding Texts[StartAfterRestartSchedule]}" IsChecked="{Binding Settings.RandomQuestScheduledMode}" />
                                    <TextBlock Text="{Binding Texts[RandomRestartTimesLocal]}" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.RandomQuestRestartTimes, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{Binding Texts[RandomQuestIntervalMinutes]}" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.RandomQuestIntervalMinutes, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{Binding Texts[RandomQuestStartDelayMinutes]}" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.RandomQuestStartDelayMinutes, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Content="{Binding Texts[Save]}" Command="{Binding SaveSettingsCommand}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
