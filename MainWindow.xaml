<Window x:Class="ScumRconTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:services="clr-namespace:ScumRconTool.Services"
        xmlns:viewModels="clr-namespace:ScumRconTool.ViewModels"
        Title="Red Raven Rcon Tool" Height="900" Width="1380" MinHeight="760" MinWidth="1180">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#101016"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="0,0,1,0"
                Padding="18">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <Image Source="Assets/logo.png"
                           Height="118"
                           Stretch="Uniform"
                           Margin="0,0,0,14" />
                    <TextBlock Text="Red Raven"
                               FontSize="24"
                               FontWeight="Bold"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Rcon Tool"
                               Foreground="{StaticResource MutedTextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,18" />

                    <Border Background="#17171F"
                            BorderBrush="{StaticResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Version"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding VersionText}"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontWeight="Bold"
                                       Margin="0,4,0,0" />
                            <TextBlock Text="{Binding UpdateStatusText}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,10" />
                            <Button Content="{Binding UpdateButtonText}"
                                    Command="{Binding CheckForUpdatesCommand}"
                                    Margin="0,0,0,8" />
                            <Button Content="{Binding Texts[OpenDownload]}"
                                    Command="{Binding OpenUpdateDownloadCommand}"
                                    Margin="0,0,0,8" />
                            <Button Content="{Binding Texts[SwitchLanguage]}"
                                    Command="{Binding SwitchLanguageCommand}"
                                    Margin="0,0,0,8" />
                            <Button Content="{Binding Texts[GgconDocs]}"
                                    Command="{Binding OpenGgconDocsCommand}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <TextBlock Text="{Binding Texts[Status]}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <Border Background="#17171F"
                            BorderBrush="{StaticResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="RCON" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Text="{Binding RconConnected}" HorizontalAlignment="Right" FontWeight="Bold" />
                            </DockPanel>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="{Binding Texts[CurrentPlayers]}" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Text="{Binding CurrentPlayersStatus}" HorizontalAlignment="Right" FontWeight="Bold" />
                            </DockPanel>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="Discord" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Text="{Binding DiscordStatus}" HorizontalAlignment="Right" FontWeight="Bold" />
                            </DockPanel>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="{Binding Texts[AutoMessages]}" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Text="{Binding AutoMessagesRunning}" HorizontalAlignment="Right" FontWeight="Bold" />
                            </DockPanel>
                            <DockPanel>
                                <TextBlock Text="{Binding Texts[ScriptZone]}" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Text="{Binding ScriptEngineRunning}" HorizontalAlignment="Right" FontWeight="Bold" />
                            </DockPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="18">
            <TabControl x:Name="MainTabs" Background="Transparent">
                <TabItem Header="{Binding Texts[Dashboard]}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Red Raven Rcon Tool" FontSize="34" FontWeight="Bold" Margin="0,0,0,6" />
                            <TextBlock Text="{Binding Texts[Dashboard]}" Foreground="{StaticResource MutedTextBrush}" FontSize="18" Margin="0,0,0,18" />
                            <WrapPanel>
                                <Border Style="{StaticResource Card}" Width="260">
                                    <StackPanel>
                                        <TextBlock Text="RCON" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding RconConnected}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Text="{Binding Texts[SourceRconConnection]}" Foreground="{StaticResource MutedTextBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Width="260">
                                    <StackPanel>
                                        <TextBlock Text="Discord" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding DiscordStatus}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Text="Bridge + Embeds" Foreground="{StaticResource MutedTextBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Width="260">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Texts[ChatCommands]}" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ChatCommandsRunning}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Text="{Binding Texts[IngameChatCommandsShort]}" Foreground="{StaticResource MutedTextBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Width="260">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Texts[JoinCommands]}" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding JoinCommandsRunning}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Text="{Binding Texts[LoginDelayCommandsShort]}" Foreground="{StaticResource MutedTextBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Width="260">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Texts[KillFeed]}" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding KillFeedRunning}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Text="Killlog -&gt; Ingame Broadcast" Foreground="{StaticResource MutedTextBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Width="260">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Texts[WeeklyTasks]}" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding WeeklyTasksRunning}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Text="{Binding WeeklyTaskStatus}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Width="260">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Texts[AutoMessages]}" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding AutoMessagesRunning}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Text="{Binding AutoMessageStatus}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Width="260">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Texts[Scripts]}" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Scripts.Count}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Text="{Binding Texts[JsonEventFiles]}" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock Text="Engine" Foreground="{StaticResource MutedTextBrush}" Margin="0,10,0,0" />
                                        <TextBlock Text="{Binding ScriptEngineRunning}" FontWeight="Bold" />
                                    </StackPanel>
                                </Border>
                            </WrapPanel>

                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,10">
                                        <TextBlock Text="{Binding Texts[ScriptStatus]}" FontSize="18" FontWeight="SemiBold" DockPanel.Dock="Left" />
                                        <TextBlock Text="{Binding ScriptRuntimeSummary}" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Right" />
                                    </DockPanel>
                                    <TextBlock Text="{Binding Texts[ScriptStatusHint]}" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,10" />
                                    <ItemsControl ItemsSource="{Binding ScriptRuntimeStatuses}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,10,10" Padding="12" CornerRadius="10" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" MinWidth="220" Background="#1E1E26">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#1E1E26" />
                                                            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding State}" Value="Initiated">
                                                                    <Setter Property="Background" Value="#0E2A44" />
                                                                    <Setter Property="BorderBrush" Value="#2D9CDB" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding State}" Value="Live">
                                                                    <Setter Property="Background" Value="#12351E" />
                                                                    <Setter Property="BorderBrush" Value="#27AE60" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding State}" Value="CleanupPending">
                                                                    <Setter Property="Background" Value="#3A2A10" />
                                                                    <Setter Property="BorderBrush" Value="#F2994A" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding State}" Value="Cooldown">
                                                                    <Setter Property="Background" Value="#27272F" />
                                                                    <Setter Property="BorderBrush" Value="#777777" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                            <TextBlock Text="{Binding StateLabel}" FontWeight="Bold" />
                                                            <TextBlock Text="  |  " Foreground="{StaticResource MutedTextBrush}" />
                                                            <TextBlock Text="{Binding Mode}" Foreground="{StaticResource MutedTextBrush}" />
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Group, StringFormat={}Gruppe: {0}}" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                                                        <TextBlock Text="{Binding CooldownUntil, StringFormat={}Cooldown bis: {0}}" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0" />
                                                        <TextBlock Text="{Binding LastAction, StringFormat={}Live: {0}}" TextWrapping="Wrap" Margin="0,6,0,0" />
                                                        <TextBlock Text="{Binding LastLootSummary, StringFormat={}Loot: {0}}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding LastRawCommand, StringFormat={}Raw: {0}}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" FontFamily="Consolas" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,10">
                                        <TextBlock Text="{Binding Texts[LastActions]}" FontSize="18" FontWeight="SemiBold" DockPanel.Dock="Left" />
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Content="{Binding Texts[OpenFolder]}" Command="{Binding OpenLogFolderCommand}" />
                                            <Button Content="{Binding Texts[Clear]}" Command="{Binding ClearLogCommand}" />
                                        </StackPanel>
                                    </DockPanel>
                                    <ListBox ItemsSource="{Binding LogLines}" Height="420" Background="#101016" Foreground="{StaticResource AppTextBrush}" BorderBrush="{StaticResource AppBorderBrush}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="{Binding Texts[RconConsole]}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="{Binding Texts[RconConsole]}" FontSize="28" FontWeight="Bold" />
                                <TextBlock Text="{Binding Texts[RconConsoleDescription]}" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,16" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="{Binding Texts[Connect]}" Command="{Binding ConnectRconCommand}" />
                                    <Button Content="{Binding Texts[Send]}" Command="{Binding SendRconCommand}" />
                                </StackPanel>
                                <TextBlock Text="Command" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBox Text="{Binding RconCommand, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource Card}">
                            <TextBox Text="{Binding LastRconResponse}" FontFamily="Consolas" AcceptsReturn="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" IsReadOnly="True" />
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="{Binding Texts[DiscordBridge]}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="{Binding Texts[DiscordBridge]}" FontSize="34" FontWeight="Bold" Margin="0,0,0,18" />
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Bot" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Texts[DiscordBotDescription]}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,16" />
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="{Binding Texts[StartDiscord]}" Command="{Binding StartDiscordCommand}" />
                                        <Button Content="{Binding Texts[UpdateServerStatus]}" Command="{Binding UpdateServerStatusCommand}" />
                                        <Button Content="{Binding Texts[StartChatLogAuto]}" Command="{Binding StartChatLogForwarderCommand}" />
                                        <Button Content="{Binding Texts[StopChatLogAuto]}" Command="{Binding StopChatLogForwarderCommand}" />
                                        <Button Content="{Binding Texts[SendChatLogEmbedsNow]}" Command="{Binding ScanChatLogCommand}" />
                                        <Button Content="{Binding Texts[SaveSettings]}" Command="{Binding SaveSettingsCommand}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="{Binding Texts[ChatlogForwarderActive], StringFormat={}{0}: }" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock Text="{Binding ChatLogForwarderRunning}" Foreground="{StaticResource MutedTextBrush}" />
                                    </StackPanel>
                                    <TextBlock Text="Discord Token" Foreground="{StaticResource MutedTextBrush}" />
                                    <PasswordBox x:Name="DiscordTokenBox" PasswordChanged="DiscordTokenBox_PasswordChanged" />
                                    <TextBlock Text="Chatlog Embed Channel-ID" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.DiscordChatLogChannelId, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Discord → Game Bridge Channel-ID" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.DiscordGameBridgeChannelId, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{Binding Texts[ServerStatusChannelId]}" Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0" />
                                    <TextBox Text="{Binding Settings.DiscordServerStatusChannelId, UpdateSourceTrigger=PropertyChanged}" />
                                    <CheckBox Content="{Binding Texts[ServerStatusAutoUpdate]}" IsChecked="{Binding Settings.AutoStartDiscordServerStatusMessage}" Foreground="{StaticResource AppTextBrush}" Margin="0,4,0,4" />
                                    <CheckBox Content="{Binding Texts[DiscordBotStatusUpdate]}" IsChecked="{Binding Settings.AutoStartDiscordBotStatus}" Foreground="{StaticResource AppTextBrush}" Margin="0,0,0,4" />
                                    <TextBlock Text="Botstatus Template" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.DiscordBotStatusTemplate, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{Binding Texts[ServerStatusTitle]}" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.DiscordServerStatusTitle, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{Binding Texts[ServerName]}" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.DiscordServerName, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{Binding Texts[ServerAddressHint]}" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.DiscordServerAddress, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{Binding Texts[DiscordGgconCentralHint]}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,8,0,0" />
                                    <CheckBox Content="{Binding Texts[CheckUpdatesOnStart]}" IsChecked="{Binding Settings.AutoCheckForUpdates}" Foreground="{StaticResource AppTextBrush}" Margin="0,10,0,4" />
                                    <TextBlock Text="Update latest.json URL" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.UpdateLatestJsonUrl, UpdateSourceTrigger=PropertyChanged}" />
                                    <CheckBox Content="{Binding Texts[DiscordIngameEnable]}" IsChecked="{Binding Settings.DiscordGameBridgeEnabled}" Foreground="{StaticResource AppTextBrush}" Margin="0,4,0,10" />
                                    <CheckBox Content="{Binding Texts[ChatlogEmbedsEnable]}" IsChecked="{Binding Settings.DiscordChatLogEmbedsEnabled}" Foreground="{StaticResource AppTextBrush}" Margin="0,4,0,4" />
                                    <CheckBox Content="{Binding Texts[VehicleLogEmbedsEnable]}" IsChecked="{Binding Settings.DiscordVehicleLogEmbedsEnabled}" Foreground="{StaticResource AppTextBrush}" Margin="0,0,0,4" />
                                    <CheckBox Content="{Binding Texts[ChatlogsAutoStart]}" IsChecked="{Binding Settings.AutoStartDiscordChatLogs}" Foreground="{StaticResource AppTextBrush}" Margin="0,0,0,10" />
                                    <TextBlock Text="{Binding Texts[GameBridgeMessageType]}" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.DiscordGameBridgeMessageType, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>


                <TabItem Header="{Binding Texts[ChatCommands]}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource Card}" MaxHeight="330">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="{Binding Texts[ChatCommands]}" FontSize="34" FontWeight="Bold" />
                                <TextBlock Text="{Binding Texts[ChatCommandsDescription]}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,14" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="{Binding Texts[Start]}" Command="{Binding StartChatCommandsCommand}" />
                                    <Button Content="{Binding Texts[Stop]}" Command="{Binding StopChatCommandsCommand}" />
                                    <Button Content="{Binding Texts[ScanNow]}" Command="{Binding ScanChatCommandsCommand}" />
                                    <Button Content="{Binding Texts[AddCommand]}" Command="{Binding AddChatCommandRuleCommand}" />
                                    <Button Content="{Binding Texts[InsertExamples]}" Command="{Binding InsertDefaultChatCommandsCommand}" />
                                    <Button Content="{Binding Texts[Save]}" Command="{Binding SaveSettingsCommand}" />
                                </StackPanel>
                                <CheckBox Content="{Binding Texts[ChatAutoStart]}" IsChecked="{Binding Settings.AutoStartChatCommands}" Margin="0,8,0,0" />
                                <TextBlock Text="{Binding Texts[ChatSharedSourceHint]}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,8,0,0" />
                                <CheckBox Content="{Binding Texts[WelcomeNewPlayers]}" IsChecked="{Binding Settings.NewPlayerWelcomeEnabled}" Margin="0,10,0,0" />
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="{Binding Texts[WelcomeType]}" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                                    <ComboBox Width="150" Margin="12,0,0,0" ItemsSource="{Binding BroadcastMessageTypes}" SelectedItem="{Binding Settings.NewPlayerWelcomeMessageType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <TextBlock Text="{Binding Texts[WelcomeMessage]}" Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0" />
                                <TextBox Text="{Binding Settings.NewPlayerWelcomeResponse, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Texts[WelcomeHint]}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,4,0,0" />
                                <CheckBox Content="{Binding Texts[PaidVotes]}" IsChecked="{Binding Settings.PaidVotesEnabled}" Margin="0,10,0,0" />
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="{Binding Texts[VotePrice]}" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                                    <TextBox Width="90" Margin="12,0,6,0" Text="{Binding Settings.VotePrice, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="$" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Texts[Confirmation]}" Foreground="{StaticResource MutedTextBrush}" Margin="20,0,8,0" VerticalAlignment="Center" />
                                    <TextBox Width="70" Text="{Binding Settings.VoteConfirmationTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{Binding Texts[Seconds]}" Foreground="{StaticResource MutedTextBrush}" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="{Binding Texts[VotePrompt]}" Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0" />
                                <TextBox Text="{Binding Settings.VotePurchasePromptResponse, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Texts[VoteInsufficientFunds]}" Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0" />
                                <TextBox Text="{Binding Settings.VoteInsufficientFundsResponse, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />
                                <TextBlock Text="Platzhalter: {name}, {steamId}, {cost}, {price}, {balance}, {timeoutSeconds}, {confirmCommand}, {voteCommand}, {remaining}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,4,0,0" />
                                <TextBlock Text="Status" Foreground="{StaticResource MutedTextBrush}" Margin="0,10,0,0" />
                                <TextBlock Text="{Binding ChatCommandsRunning}" FontWeight="Bold" />
                            </StackPanel>
                            </ScrollViewer>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,14,0,0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="{Binding Texts[Commands]}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <TextBlock DockPanel.Dock="Top" Text="{Binding Texts[ChatCommandsHelp]}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,12" />
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding ChatCommandRules}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Expander IsExpanded="True" Margin="0,0,0,10">
                                                    <Expander.Header>
                                                        <DockPanel LastChildFill="True" Width="760">
                                                            <CheckBox DockPanel.Dock="Left" IsChecked="{Binding Enabled}" Margin="0,0,10,0" VerticalAlignment="Center" />
                                                            <TextBlock Text="{Binding Summary}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                        </DockPanel>
                                                    </Expander.Header>
                                                    <Border Background="#101016" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,8,0,0">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="180" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Text="{Binding DataContext.Texts[Trigger], RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                <TextBox Width="220" Text="{Binding Trigger, UpdateSourceTrigger=PropertyChanged}" />
                                                                <TextBlock Text="{Binding DataContext.Texts[Match], RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{StaticResource MutedTextBrush}" Margin="18,0,8,0" VerticalAlignment="Center" />
                                                                <ComboBox Width="130" ItemsSource="{Binding DataContext.ChatMatchModes, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding MatchMode, UpdateSourceTrigger=PropertyChanged}" />
                                                                <TextBlock Text="{Binding DataContext.Texts[Delay], RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{StaticResource MutedTextBrush}" Margin="18,0,8,0" VerticalAlignment="Center" />
                                                                <TextBox Width="80" Text="{Binding DelaySeconds, UpdateSourceTrigger=PropertyChanged}" />
                                                                <TextBlock Text="s" Foreground="{StaticResource MutedTextBrush}" Margin="8,0,0,0" VerticalAlignment="Center" />
                                                            </StackPanel>
                                                            <Button Grid.Column="2" Content="{Binding DataContext.Texts[RemoveDelete], RelativeSource={RelativeSource AncestorType=Window}}" Command="{Binding DataContext.RemoveChatCommandRuleCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />

