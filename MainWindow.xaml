<Window x:Class="ScumRconTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:services="clr-namespace:ScumRconTool.Services"
        Title="Red Raven Rcon Tool" Height="900" Width="1380" MinHeight="760" MinWidth="1180">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#09090D" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="0,0,1,0" Padding="18">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <Image Source="Assets/logo.png" Height="118" HorizontalAlignment="Stretch" Stretch="Uniform" Margin="0,0,0,16" />
                    <TextBlock Text="Red Raven" FontSize="30" FontWeight="Bold" />
                    <TextBlock Text="Rcon Tool" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Text="Red Raven" Foreground="{StaticResource AccentBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,30" />

                    <Button Style="{StaticResource NavButton}" Content="Dashboard" Click="NavDashboard_Click" />
                    <Button Style="{StaticResource NavButton}" Content="RCON Console" Click="NavRcon_Click" />
                    <Button Style="{StaticResource NavButton}" Content="Discord Bridge" Click="NavDiscord_Click" />
                    <Button Style="{StaticResource NavButton}" Content="Chat Commands" Click="NavChatCommands_Click" />
                    <Button Style="{StaticResource NavButton}" Content="Join Commands" Click="NavJoinCommands_Click" />
                    <Button Style="{StaticResource NavButton}" Content="Kill Feed" Click="NavKillFeed_Click" />
                    <Button Style="{StaticResource NavButton}" Content="Weekly Tasks" Click="NavWeeklyTasks_Click" />
                    <Button Style="{StaticResource NavButton}" Content="Auto Messages" Click="NavAutoMessages_Click" />
                    <Button Style="{StaticResource NavButton}" Content="Script Editor" Click="NavScripts_Click" />
                    <Button Style="{StaticResource NavButton}" Content="Debug Logs" Click="NavLogs_Click" />
                    <Button Style="{StaticResource NavButton}" Content="Settings" Click="NavSettings_Click" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <Border Style="{StaticResource Card}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="Status" FontWeight="SemiBold" FontSize="16" />
                            <TextBlock Text="RCON" Foreground="{StaticResource MutedTextBrush}" Margin="0,10,0,0" />
                            <TextBlock Text="{Binding RconConnected}" FontWeight="Bold" />
                            <TextBlock Text="Discord" Foreground="{StaticResource MutedTextBrush}" Margin="0,10,0,0" />
                            <TextBlock Text="{Binding DiscordStatus}" FontWeight="Bold" />
                            <TextBlock Text="Chat Commands" Foreground="{StaticResource MutedTextBrush}" Margin="0,10,0,0" />
                            <TextBlock Text="{Binding ChatCommandsRunning}" FontWeight="Bold" />
                            <TextBlock Text="Join Commands" Foreground="{StaticResource MutedTextBrush}" Margin="0,10,0,0" />
                            <TextBlock Text="{Binding JoinCommandsRunning}" FontWeight="Bold" />
                            <TextBlock Text="Kill Feed" Foreground="{StaticResource MutedTextBrush}" Margin="0,10,0,0" />
                            <TextBlock Text="{Binding KillFeedRunning}" FontWeight="Bold" />
                            <TextBlock Text="Weekly Tasks" Foreground="{StaticResource MutedTextBrush}" Margin="0,10,0,0" />
                            <TextBlock Text="{Binding WeeklyTasksRunning}" FontWeight="Bold" />
                            <TextBlock Text="Auto Messages" Foreground="{StaticResource MutedTextBrush}" Margin="0,10,0,0" />
                            <TextBlock Text="{Binding AutoMessagesRunning}" FontWeight="Bold" />
                            <TextBlock Text="Script Engine" Foreground="{StaticResource MutedTextBrush}" Margin="0,10,0,0" />
                            <TextBlock Text="{Binding ScriptEngineRunning}" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <TabControl x:Name="MainTabs" Background="Transparent">
                <TabItem Header="Dashboard">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Red Raven Rcon Tool" FontSize="34" FontWeight="Bold" Margin="0,0,0,6" />
                            <TextBlock Text="Dashboard" Foreground="{StaticResource MutedTextBrush}" FontSize="18" Margin="0,0,0,18" />
                            <WrapPanel>
                                <Border Style="{StaticResource Card}" Width="260">
                                    <StackPanel>
                                        <TextBlock Text="RCON" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding RconConnected}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Text="Source-RCON Verbindung" Foreground="{StaticResource MutedTextBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Width="260">
                                    <StackPanel>
                                        <TextBlock Text="Discord" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding DiscordStatus}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Text="Bridge + Embeds" Foreground="{StaticResource MutedTextBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Width="260">
                                    <StackPanel>
                                        <TextBlock Text="Chat Commands" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ChatCommandsRunning}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Text="Ingame-Chat Befehle" Foreground="{StaticResource MutedTextBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Width="260">
                                    <StackPanel>
                                        <TextBlock Text="Join Commands" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding JoinCommandsRunning}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Text="Loginlog Delay-Befehle" Foreground="{StaticResource MutedTextBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Width="260">
                                    <StackPanel>
                                        <TextBlock Text="Kill Feed" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding KillFeedRunning}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Text="Killlog -&gt; Ingame Broadcast" Foreground="{StaticResource MutedTextBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Width="260">
                                    <StackPanel>
                                        <TextBlock Text="Weekly Tasks" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding WeeklyTasksRunning}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Text="{Binding WeeklyTaskStatus}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Width="260">
                                    <StackPanel>
                                        <TextBlock Text="Auto Messages" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding AutoMessagesRunning}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Text="{Binding AutoMessageStatus}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Width="260">
                                    <StackPanel>
                                        <TextBlock Text="Scripts" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Scripts.Count}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Text="JSON Event-Dateien" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock Text="Engine" Foreground="{StaticResource MutedTextBrush}" Margin="0,10,0,0" />
                                        <TextBlock Text="{Binding ScriptEngineRunning}" FontWeight="Bold" />
                                    </StackPanel>
                                </Border>
                            </WrapPanel>

                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,10">
                                        <TextBlock Text="Script Status" FontSize="18" FontWeight="SemiBold" DockPanel.Dock="Left" />
                                        <TextBlock Text="{Binding ScriptRuntimeSummary}" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Right" />
                                    </DockPanel>
                                    <TextBlock Text="Blau = initialisiert/scharf, Gruen = gestartet/live." Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,10" />
                                    <ItemsControl ItemsSource="{Binding ScriptRuntimeStatuses}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,10,10" Padding="12" CornerRadius="10" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" MinWidth="220" Background="#1E1E26">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#1E1E26" />
                                                            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding State}" Value="Initiated">
                                                                    <Setter Property="Background" Value="#0E2A44" />
                                                                    <Setter Property="BorderBrush" Value="#2D9CDB" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding State}" Value="Live">
                                                                    <Setter Property="Background" Value="#12351E" />
                                                                    <Setter Property="BorderBrush" Value="#27AE60" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding State}" Value="CleanupPending">
                                                                    <Setter Property="Background" Value="#3A2A10" />
                                                                    <Setter Property="BorderBrush" Value="#F2994A" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding State}" Value="Cooldown">
                                                                    <Setter Property="Background" Value="#27272F" />
                                                                    <Setter Property="BorderBrush" Value="#777777" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                            <TextBlock Text="{Binding StateLabel}" FontWeight="Bold" />
                                                            <TextBlock Text="  |  " Foreground="{StaticResource MutedTextBrush}" />
                                                            <TextBlock Text="{Binding Mode}" Foreground="{StaticResource MutedTextBrush}" />
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Group, StringFormat={}Gruppe: {0}}" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                                                        <TextBlock Text="{Binding CooldownUntil, StringFormat={}Cooldown bis: {0}}" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0" />
                                                        <TextBlock Text="{Binding LastAction, StringFormat={}Live: {0}}" TextWrapping="Wrap" Margin="0,6,0,0" />
                                                        <TextBlock Text="{Binding LastLootSummary, StringFormat={}Loot: {0}}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding LastRawCommand, StringFormat={}Raw: {0}}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" FontFamily="Consolas" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,10">
                                        <TextBlock Text="Letzte Aktionen" FontSize="18" FontWeight="SemiBold" DockPanel.Dock="Left" />
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Content="Ordner" Command="{Binding OpenLogFolderCommand}" />
                                            <Button Content="Leeren" Command="{Binding ClearLogCommand}" />
                                        </StackPanel>
                                    </DockPanel>
                                    <ListBox ItemsSource="{Binding LogLines}" Height="420" Background="#101016" Foreground="{StaticResource AppTextBrush}" BorderBrush="{StaticResource AppBorderBrush}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="RCON Console">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="RCON Console" FontSize="28" FontWeight="Bold" />
                                <TextBlock Text="Befehle werden an ggCON per Source-RCON gesendet. Antworten sind in der Regel JSON." Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,16" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Verbinden" Command="{Binding ConnectRconCommand}" />
                                    <Button Content="Senden" Command="{Binding SendRconCommand}" />
                                </StackPanel>
                                <TextBlock Text="Command" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBox Text="{Binding RconCommand, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource Card}">
                            <TextBox Text="{Binding LastRconResponse}" FontFamily="Consolas" AcceptsReturn="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" IsReadOnly="True" />
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Discord Bridge">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Discord Bridge" FontSize="34" FontWeight="Bold" Margin="0,0,0,18" />
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Bot" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="Der Bot liest nur den angegebenen Bridge-Channel und baut daraus sichere Broadcasts. Nachrichten mit #, /, !, ., ; oder $ am Anfang werden blockiert." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,16" />
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Discord starten" Command="{Binding StartDiscordCommand}" />
                                        <Button Content="Playerlist aktualisieren" Command="{Binding UpdatePlayerListCommand}" />
                                        <Button Content="Chatlog Auto starten" Command="{Binding StartChatLogForwarderCommand}" />
                                        <Button Content="Chatlog Auto stoppen" Command="{Binding StopChatLogForwarderCommand}" />
                                        <Button Content="Chatlog jetzt als Embeds senden" Command="{Binding ScanChatLogCommand}" />
                                        <Button Content="Einstellungen speichern" Command="{Binding SaveSettingsCommand}" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding ChatLogForwarderRunning, StringFormat={}Chatlog Forwarder aktiv: {0}}" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8" />
                                    <TextBlock Text="Discord Token" Foreground="{StaticResource MutedTextBrush}" />
                                    <PasswordBox x:Name="DiscordTokenBox" PasswordChanged="DiscordTokenBox_PasswordChanged" />
                                    <TextBlock Text="Chatlog Embed Channel-ID" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.DiscordChatLogChannelId, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Discord → Game Bridge Channel-ID" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.DiscordGameBridgeChannelId, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Playerlist Channel-ID" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.DiscordPlayerListChannelId, UpdateSourceTrigger=PropertyChanged}" />
                                    <CheckBox Content="Discord → Ingame aktivieren" IsChecked="{Binding Settings.DiscordGameBridgeEnabled}" Foreground="{StaticResource AppTextBrush}" Margin="0,4,0,10" />
                                    <CheckBox Content="Chatlogs als Embed aktivieren" IsChecked="{Binding Settings.DiscordChatLogEmbedsEnabled}" Foreground="{StaticResource AppTextBrush}" Margin="0,4,0,4" />
                                    <CheckBox Content="Chatlogs automatisch starten" IsChecked="{Binding Settings.AutoStartDiscordChatLogs}" Foreground="{StaticResource AppTextBrush}" Margin="0,0,0,10" />
                                    <CheckBox Content="Discord Status automatisch starten" IsChecked="{Binding Settings.AutoStartDiscordStatus}" Foreground="{StaticResource AppTextBrush}" Margin="0,0,0,4" />
                                    <CheckBox Content="Playerlist automatisch aktualisieren" IsChecked="{Binding Settings.AutoStartDiscordPlayerList}" Foreground="{StaticResource AppTextBrush}" Margin="0,0,0,4" />
                                    <CheckBox Content="Aktive Random Events im Playerlist-Channel anzeigen" IsChecked="{Binding Settings.AutoStartDiscordRandomEvents}" Foreground="{StaticResource AppTextBrush}" Margin="0,0,0,10" />
                                    <TextBlock Text="Message Type fuer Ingame-Broadcast" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.DiscordGameBridgeMessageType, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>


                <TabItem Header="Chat Commands">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Chat Commands" FontSize="34" FontWeight="Bold" />
                                <TextBlock Text="Liest den SCUM-Chatlog per SFTP und fuehrt passende Regeln per RCON aus. Die Regeln werden unten als einzelne, aufklappbare Commands gepflegt; kein rohes JSON mehr noetig. Die Command-Felder haben SCUM-Autovervollstaendigung. Mit ExecAs wird die SteamID des Chat-Spielers automatisch eingefuegt." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,14" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Start" Command="{Binding StartChatCommandsCommand}" />
                                    <Button Content="Stop" Command="{Binding StopChatCommandsCommand}" />
                                    <Button Content="Scan jetzt" Command="{Binding ScanChatCommandsCommand}" />
                                    <Button Content="+ Command" Command="{Binding AddChatCommandRuleCommand}" />
                                    <Button Content="Beispiele einfuegen" Command="{Binding InsertDefaultChatCommandsCommand}" />
                                    <Button Content="Speichern" Command="{Binding SaveSettingsCommand}" />
                                </StackPanel>
                                <CheckBox Content="Chat Commands automatisch starten" IsChecked="{Binding Settings.AutoStartChatCommands}" Margin="0,8,0,0" />
                                <TextBlock Text="Status" Foreground="{StaticResource MutedTextBrush}" Margin="0,10,0,0" />
                                <TextBlock Text="{Binding ChatCommandsRunning}" FontWeight="Bold" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,14,0,0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Commands" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <TextBlock DockPanel.Dock="Top" Text="Pro Eintrag: Trigger setzen, Match-Art waehlen, optional Delay in Sekunden, Command und/oder Antwort eintragen. Im Command-Feld tippen oder Pfeil oeffnen fuer Vorschlaege. ExecAs fuehrt den Command automatisch fuer den Spieler aus, der den Chat-Befehl geschrieben hat. Platzhalter: {name}, {playerName}, {steamId}, {message}, {rawLine}." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,12" />
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding ChatCommandRules}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Expander IsExpanded="True" Margin="0,0,0,10">
                                                    <Expander.Header>
                                                        <DockPanel LastChildFill="True" Width="760">
                                                            <CheckBox DockPanel.Dock="Left" IsChecked="{Binding Enabled}" Margin="0,0,10,0" VerticalAlignment="Center" />
                                                            <TextBlock Text="{Binding Summary}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                        </DockPanel>
                                                    </Expander.Header>
                                                    <Border Background="#101016" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,8,0,0">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="180" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Text="Trigger" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                <TextBox Width="220" Text="{Binding Trigger, UpdateSourceTrigger=PropertyChanged}" />
                                                                <TextBlock Text="Match" Foreground="{StaticResource MutedTextBrush}" Margin="18,0,8,0" VerticalAlignment="Center" />
                                                                <ComboBox Width="130" ItemsSource="{Binding DataContext.ChatMatchModes, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding MatchMode, UpdateSourceTrigger=PropertyChanged}" />
                                                                <TextBlock Text="Delay" Foreground="{StaticResource MutedTextBrush}" Margin="18,0,8,0" VerticalAlignment="Center" />
                                                                <TextBox Width="80" Text="{Binding DelaySeconds, UpdateSourceTrigger=PropertyChanged}" />
                                                                <TextBlock Text="s" Foreground="{StaticResource MutedTextBrush}" Margin="8,0,0,0" VerticalAlignment="Center" />
                                                            </StackPanel>
                                                            <Button Grid.Column="2" Content="- Loeschen" Command="{Binding DataContext.RemoveChatCommandRuleCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />

                                                            <TextBlock Grid.Row="1" Text="Command" Foreground="{StaticResource MutedTextBrush}" Margin="0,10,0,0" VerticalAlignment="Top" />
                                                            <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" IsEditable="True" IsTextSearchEnabled="True" StaysOpenOnEdit="True" ItemsSource="{Binding DataContext.ScumCommandSuggestions, RelativeSource={RelativeSource AncestorType=Window}}" Text="{Binding Command, UpdateSourceTrigger=PropertyChanged}" Margin="0,10,0,0" MinHeight="42" />

                                                            <TextBlock Grid.Row="2" Text="Antwort" Foreground="{StaticResource MutedTextBrush}" Margin="0,10,0,0" VerticalAlignment="Top" />
                                                            <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding Response, UpdateSourceTrigger=PropertyChanged}" Margin="0,10,0,0" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="54" VerticalScrollBarVisibility="Auto" />

                                                            <StackPanel Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,12,0,0">
                                                                <CheckBox Content="Als ExecAs ausfuehren" IsChecked="{Binding ExecuteAsChatPlayer}" VerticalAlignment="Center" />
                                                                <TextBlock Text="Cooldown" Foreground="{StaticResource MutedTextBrush}" Margin="24,0,8,0" VerticalAlignment="Center" />
                                                                <TextBox Width="90" Text="{Binding CooldownSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                                                <TextBlock Text="Sekunden" Foreground="{StaticResource MutedTextBrush}" Margin="8,0,14,0" VerticalAlignment="Center" />
                                                                <TextBlock Text="Scope" Foreground="{StaticResource MutedTextBrush}" Margin="10,0,8,0" VerticalAlignment="Center" />
                                                                <ComboBox Width="110" ItemsSource="{Binding DataContext.ChatCooldownScopes, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding CooldownScope, UpdateSourceTrigger=PropertyChanged}" />
                                                            </StackPanel>

                                                            <StackPanel Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,12,0,0">
                                                                <TextBlock Text="Globaler Anti-Spam Cooldown" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                                                                <TextBox Width="90" Margin="12,0,0,0" Text="{Binding GlobalCooldownSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                                                <TextBlock Text="Sekunden" Foreground="{StaticResource MutedTextBrush}" Margin="8,0,0,0" VerticalAlignment="Center" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </Expander>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Join Commands">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Join Commands" FontSize="34" FontWeight="Bold" />
                                <TextBlock Text="Liest den SCUM-Loginlog per SFTP und plant nach einem Join verzoegerte RCON-Befehle. Die Regeln werden unten als einzelne Commands gepflegt; kein rohes JSON mehr noetig. Die Command-Felder haben SCUM-Autovervollstaendigung. Mit ExecAs wird die SteamID des joinenden Spielers automatisch eingefuegt." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,14" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Start" Command="{Binding StartJoinCommandsCommand}" />
                                    <Button Content="Stop" Command="{Binding StopJoinCommandsCommand}" />
                                    <Button Content="Scan jetzt" Command="{Binding ScanJoinCommandsCommand}" />
                                    <Button Content="Fuer alle Online-Spieler ausfuehren" Command="{Binding ExecuteJoinCommandsForOnlinePlayersCommand}" />
                                    <Button Content="+ Command" Command="{Binding AddJoinCommandRuleCommand}" />
                                    <Button Content="Beispiel einfuegen" Command="{Binding InsertDefaultJoinCommandsCommand}" />
                                    <Button Content="Speichern" Command="{Binding SaveSettingsCommand}" />
                                </StackPanel>
                                <CheckBox Content="Join Commands automatisch starten" IsChecked="{Binding Settings.AutoStartJoinCommands}" Margin="0,8,0,0" />
                                <TextBlock Text="Status" Foreground="{StaticResource MutedTextBrush}" Margin="0,10,0,0" />
                                <TextBlock Text="{Binding JoinCommandsRunning}" FontWeight="Bold" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,14,0,0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Commands" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <TextBlock DockPanel.Dock="Top" Text="Pro Eintrag: aktivieren, Delay in Sekunden setzen, Command eintippen oder aus der Vorschlagsliste waehlen und optional als ExecAs fuer den joinenden Spieler ausfuehren. &quot;Nur einmal pro Join&quot; meint dieselbe erkannte Login-Zeile; bei einem spaeteren Rejoin kann der Command wieder laufen. Platzhalter bleiben moeglich: {name}, {playerName}, {steamId}, {rawLine}." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,12" />
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding JoinCommandRules}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Expander IsExpanded="True" Margin="0,0,0,10">
                                                    <Expander.Header>
                                                        <DockPanel LastChildFill="True" Width="760">
                                                            <CheckBox DockPanel.Dock="Left" IsChecked="{Binding Enabled}" Margin="0,0,10,0" VerticalAlignment="Center" />
                                                            <TextBlock Text="{Binding Summary}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                        </DockPanel>
                                                    </Expander.Header>
                                                    <Border Background="#101016" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,8,0,0">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="180" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Text="Delay seconds" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                                                            <TextBox Grid.Column="1" Width="120" HorizontalAlignment="Left" Text="{Binding DelaySeconds, UpdateSourceTrigger=PropertyChanged}" />
                                                            <Button Grid.Column="2" Content="- Loeschen" Command="{Binding DataContext.RemoveJoinCommandRuleCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />

                                                            <TextBlock Grid.Row="1" Text="Command" Foreground="{StaticResource MutedTextBrush}" Margin="0,10,0,0" VerticalAlignment="Top" />
                                                            <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" IsEditable="True" IsTextSearchEnabled="True" StaysOpenOnEdit="True" ItemsSource="{Binding DataContext.ScumCommandSuggestions, RelativeSource={RelativeSource AncestorType=Window}}" Text="{Binding Command, UpdateSourceTrigger=PropertyChanged}" Margin="0,10,0,0" MinHeight="42" />

                                                            <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,12,0,0">
                                                                <CheckBox Content="Als ExecAs ausfuehren" IsChecked="{Binding ExecuteAsJoinedPlayer}" VerticalAlignment="Center" />
                                                                <CheckBox Content="Nur einmal pro Join ausfuehren" IsChecked="{Binding OnlyOncePerSession}" Margin="24,0,0,0" VerticalAlignment="Center" ToolTip="Verhindert doppelte Ausfuehrung fuer dieselbe erkannte Login-Zeile. Wenn der Spieler spaeter neu joined, kann der Command wieder geplant werden." />
                                                                <TextBlock Text="Cooldown" Foreground="{StaticResource MutedTextBrush}" Margin="24,0,8,0" VerticalAlignment="Center" />
                                                                <TextBox Width="90" Text="{Binding CooldownSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                                                <TextBlock Text="Sekunden" Foreground="{StaticResource MutedTextBrush}" Margin="8,0,0,0" VerticalAlignment="Center" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </Expander>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </Grid>
                </TabItem>


                <TabItem Header="Kill Feed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Kill Feed" FontSize="34" FontWeight="Bold" Margin="0,0,0,18" />
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Killlog -&gt; Ingame Broadcast" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="Lädt die neueste Killlog-Datei per SFTP, merkt bereits bekannte Kill-Zeilen und sendet neue Kills als #Broadcast mit einstellbarer Farbe in den Ingamechat. Beim allerersten Lauf werden vorhandene Zeilen nur gemerkt, damit alte Kills nicht gespammt werden." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,14" />
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Start" Command="{Binding StartKillFeedCommand}" />
                                        <Button Content="Stop" Command="{Binding StopKillFeedCommand}" />
                                        <Button Content="Scan jetzt" Command="{Binding ScanKillFeedCommand}" />
                                        <Button Content="Speichern" Command="{Binding SaveSettingsCommand}" />
                                    </StackPanel>
                                    <CheckBox Content="Killfeed automatisch starten" IsChecked="{Binding Settings.AutoStartKillFeed}" Margin="0,8,0,0" />
                                    <TextBlock Text="Status" Foreground="{StaticResource MutedTextBrush}" Margin="0,10,0,0" />
                                    <TextBlock Text="{Binding KillFeedRunning}" FontWeight="Bold" />
                                    <TextBlock Text="Killlog Pattern" Foreground="{StaticResource MutedTextBrush}" Margin="0,14,0,0" />
                                    <TextBox Text="{Binding Settings.FtpKillLogPattern, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Poll Sekunden" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.KillPollSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Ingame Nachricht Farbe" Foreground="{StaticResource MutedTextBrush}" />
                                    <ComboBox ItemsSource="{Binding BroadcastMessageTypes}" SelectedItem="{Binding Settings.KillAnnounceColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Ingame Nachricht Template" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.KillAnnounceTemplate, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Platzhalter: {killer}, {victim}, {weapon}, {distance}, {time}, {raw}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Weekly Tasks">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Weekly Community Tasks" FontSize="34" FontWeight="Bold" Margin="0,0,0,18" />
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Community Fortschritt aus scum.db" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="Lädt die scum.db per SFTP, speichert beim Start einen Basiswert und berechnet danach nur die Differenz. Discord wird alle 30 Minuten aktualisiert, aber nur wenn Spieler online sind." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,14" />
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Start" Command="{Binding StartWeeklyTasksCommand}" />
                                        <Button Content="Stop" Command="{Binding StopWeeklyTasksCommand}" />
                                        <Button Content="Scan + Discord jetzt" Command="{Binding ScanWeeklyTasksCommand}" />
                                        <Button Content="Startwert neu setzen" Command="{Binding ResetWeeklyTaskBaselineCommand}" />
                                        <Button Content="JSON Reset Beispiel" Command="{Binding InsertDefaultWeeklyTaskCommand}" />
                                        <Button Content="Speichern" Command="{Binding SaveSettingsCommand}" />
                                    </StackPanel>
                                    <CheckBox Content="Weekly Tasks automatisch starten" IsChecked="{Binding Settings.AutoStartWeeklyTasks}" Margin="0,8,0,0" />
                                    <CheckBox Content="DB nur aktualisieren, wenn Spieler online sind" IsChecked="{Binding Settings.WeeklyTaskOnlyWhenPlayersOnline}" Margin="0,4,0,0" />
                                    <TextBlock Text="Status" Foreground="{StaticResource MutedTextBrush}" Margin="0,10,0,0" />
                                    <TextBlock Text="{Binding WeeklyTaskStatus}" FontWeight="Bold" TextWrapping="Wrap" />
                                    <TextBlock Text="SCUM.db Remote-Dateipfad absolut" Foreground="{StaticResource MutedTextBrush}" Margin="0,14,0,0" />
                                    <TextBox Text="{Binding Settings.WeeklyTaskDbRemoteFilePath, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Discord Channel-ID fuer Weekly Tasks (leer/0 = Playerlist Channel)" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.WeeklyTaskDiscordChannelId, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Update Intervall Minuten" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.WeeklyTaskPollMinutes, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Challenge-Planer" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="Jede Challenge ist eine eigene Card. Neue Challenges werden als neue Card angelegt, bestehende werden nicht ueberschrieben. Geplante Tasks starten ab Startzeit; abgelaufene Tasks werden nicht mehr aktualisiert/angezeigt." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,12" />

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                        <Button Content="Neue Challenge" Command="{Binding AddWeeklyTaskEditorCommand}" />
                                        <Button Content="Aus vorhandenen Daten neu laden" Command="{Binding ReloadWeeklyTaskEditorCommand}" />
                                        <Button Content="Alle Challenges speichern" Command="{Binding ApplyWeeklyTaskEditorCommand}" />
                                    </StackPanel>

                                    <ItemsControl ItemsSource="{Binding WeeklyTaskEditors}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,0,14" Background="#22000000">
                                                    <StackPanel>
                                                        <DockPanel Margin="0,0,0,10">
                                                            <StackPanel DockPanel.Dock="Left">
                                                                <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="SemiBold" />
                                                                <TextBlock Text="{Binding Id}" Foreground="{StaticResource MutedTextBrush}" />
                                                            </StackPanel>
                                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                                                <Button Content="Duplizieren" Command="{Binding DataContext.DuplicateWeeklyTaskEditorCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                                <Button Content="Loeschen" Command="{Binding DataContext.DeleteWeeklyTaskEditorCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                            </StackPanel>
                                                        </DockPanel>

                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>

                                                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                                                                <CheckBox Content="Aktiviert" IsChecked="{Binding Enabled}" />
                                                                <TextBlock Text="ID eindeutig" Foreground="{StaticResource MutedTextBrush}" />
                                                                <TextBox Text="{Binding Id, UpdateSourceTrigger=PropertyChanged}" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,8">
                                                                <TextBlock Text="Typ" Foreground="{StaticResource MutedTextBrush}" />
                                                                <ComboBox ItemsSource="{Binding DataContext.WeeklyTaskTypes, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding Type}" />
                                                            </StackPanel>

                                                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8">
                                                                <TextBlock Text="Titel" Foreground="{StaticResource MutedTextBrush}" />
                                                                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,8">
                                                                <TextBlock Text="Zielwert" Foreground="{StaticResource MutedTextBrush}" />
                                                                <TextBox Text="{Binding Target, UpdateSourceTrigger=PropertyChanged}" />
                                                            </StackPanel>

                                                            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,8">
                                                                <TextBlock Text="Ziel aus SCUM.db" Foreground="{StaticResource MutedTextBrush}" />
                                                                <ComboBox ItemsSource="{Binding DataContext.WeeklyTaskStatTargets, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding SelectedTarget}" DisplayMemberPath="FullDisplay" />
                                                            </StackPanel>

                                                            <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,8,8">
                                                                <TextBlock Text="Startzeit lokal, optional: yyyy-MM-dd HH:mm" Foreground="{StaticResource MutedTextBrush}" />
                                                                <TextBox Text="{Binding StartLocalText, UpdateSourceTrigger=PropertyChanged}" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Row="3" Grid.Column="1" Margin="8,0,0,8">
                                                                <TextBlock Text="Laufzeit Stunden" Foreground="{StaticResource MutedTextBrush}" />
                                                                <TextBox Text="{Binding DurationHours, UpdateSourceTrigger=PropertyChanged}" />
                                                            </StackPanel>

                                                            <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,8,8">
                                                                <TextBlock Text="Mindestbeteiligung Prozent" Foreground="{StaticResource MutedTextBrush}" />
                                                                <TextBox Text="{Binding MinimumParticipationPercent, UpdateSourceTrigger=PropertyChanged}" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Row="4" Grid.Column="1" Margin="8,0,0,8">
                                                                <TextBlock Text="Planung" Foreground="{StaticResource MutedTextBrush}" />
                                                                <TextBlock Text="{Binding SchedulePreview}" FontWeight="Bold" TextWrapping="Wrap" />
                                                            </StackPanel>

                                                            <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,8">
                                                                <TextBlock Text="Beschreibung" Foreground="{StaticResource MutedTextBrush}" />
                                                                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" MinHeight="50" TextWrapping="Wrap" />
                                                            </StackPanel>

                                                            <Grid Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                                    <TextBlock Text="Reward Text" Foreground="{StaticResource MutedTextBrush}" />
                                                                    <TextBox Text="{Binding RewardText, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" MinHeight="64" TextWrapping="Wrap" />
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                                    <TextBlock Text="Completed Text" Foreground="{StaticResource MutedTextBrush}" />
                                                                    <TextBox Text="{Binding CompletedText, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" MinHeight="64" TextWrapping="Wrap" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Auto Messages">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Auto Messages" FontSize="34" FontWeight="Bold" Margin="0,0,0,18" />
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Ingame-Chat Rotation" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="Sendet alle N Minuten eine Nachricht per #Broadcast, aber nur wenn Spieler online sind. Der Flow rotiert z.B. Challenge-Status, /help Hinweis, Discord Hinweis und wieder Challenge-Status." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,14" />
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Start" Command="{Binding StartAutoMessagesCommand}" />
                                        <Button Content="Stop" Command="{Binding StopAutoMessagesCommand}" />
                                        <Button Content="Jetzt senden" Command="{Binding SendAutoMessageNowCommand}" />
                                        <Button Content="Flow auf Anfang" Command="{Binding ResetAutoMessageFlowCommand}" />
                                        <Button Content="Beispiel einfuegen" Command="{Binding InsertDefaultAutoMessagesCommand}" />
                                        <Button Content="Speichern" Command="{Binding SaveSettingsCommand}" />
                                    </StackPanel>
                                    <CheckBox Content="Auto Messages automatisch starten" IsChecked="{Binding Settings.AutoStartAutoMessages}" Margin="0,8,0,0" />
                                    <CheckBox Content="Nur senden, wenn Spieler online sind" IsChecked="{Binding Settings.AutoMessagesOnlyWhenPlayersOnline}" Margin="0,4,0,0" />
                                    <TextBlock Text="Status" Foreground="{StaticResource MutedTextBrush}" Margin="0,10,0,0" />
                                    <TextBlock Text="{Binding AutoMessageStatus}" FontWeight="Bold" TextWrapping="Wrap" />
                                    <TextBlock Text="Intervall Minuten" Foreground="{StaticResource MutedTextBrush}" Margin="0,14,0,0" />
                                    <TextBox Text="{Binding Settings.AutoMessagesIntervalMinutes, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Standard Nachricht-Farbe" Foreground="{StaticResource MutedTextBrush}" />
                                    <ComboBox ItemsSource="{Binding BroadcastMessageTypes}" SelectedItem="{Binding Settings.AutoMessagesBroadcastType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Maximale Laenge pro Broadcast" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.AutoMessagesMaxLength, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Text, wenn keine Challenge aktiv ist" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.AutoMessagesNoChallengeText, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Flow als JSON" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="Type=Challenges erzeugt aktuelle Challenge-Staende. Type=Text sendet den Text. MessageType ist optional pro Schritt: Yellow, White, Cyan, Green, Red, ServerMessage, Error." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,12" />
                                    <TextBox Text="{Binding Settings.AutoMessagesFlowJson, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" AcceptsReturn="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" MinHeight="280" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Script Editor">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="310" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Top">
                                    <TextBlock Text="Scripts" FontSize="26" FontWeight="Bold" />
                                    <TextBlock Text="Ablaufbloecke statt Roh-JSON. JSON bleibt im Hintergrund kompatibel." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,12" />
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Start" Command="{Binding StartScriptsCommand}" />
                                        <Button Content="Stop" Command="{Binding StopScriptsCommand}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Scan jetzt" Command="{Binding ScanScriptsCommand}" />
                                        <Button Content="Aktualisieren" Command="{Binding RefreshScriptsCommand}" />
                                    </StackPanel>
                                    <TextBlock Text="Engine laeuft" Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0" />
                                    <TextBlock Text="{Binding ScriptEngineRunning}" FontWeight="Bold" Margin="0,0,0,12" />
                                </StackPanel>
                                <ListBox ItemsSource="{Binding Scripts}" SelectedItem="{Binding SelectedScript}" DisplayMemberPath="Name" Background="#101016" Foreground="{StaticResource AppTextBrush}" BorderBrush="{StaticResource AppBorderBrush}" />
                            </DockPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource Card}" Margin="0">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Top">
                                    <TextBlock Text="Script Ablauf Editor" FontSize="26" FontWeight="Bold" />
                                    <TextBlock Text="{Binding ScriptValidation}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,12" />
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Speichern" Click="SaveScript_Click" />
                                        <Button Content="Duplizieren" Click="DuplicateScript_Click" />
                                        <Button Content="JSON validieren" Click="ValidateScript_Click" />
                                        <Button Content="JSON formatieren" Click="FormatScript_Click" />
                                    </StackPanel>
                                </StackPanel>

                                <TabControl>
                                    <TabItem Header="Ablauf">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel DataContext="{Binding ScriptEditorModel}">
                                                <Expander Header="Titel / Main Einstellungen" IsExpanded="True" Style="{StaticResource RedExpander}">
                                                    <Grid Margin="0,10,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="150" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="150" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Text="Aktiv" Grid.Row="0" Grid.Column="0" Foreground="{StaticResource MutedTextBrush}" />
                                                        <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding Enabled}" />
                                                        <TextBlock Text="Modus" Grid.Row="0" Grid.Column="2" Foreground="{StaticResource MutedTextBrush}" />
                                                        <ComboBox Grid.Row="0" Grid.Column="3" ItemsSource="{Binding DataContext.ScriptModes, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding Mode}" />

                                                        <TextBlock Text="ID" Grid.Row="1" Grid.Column="0" Foreground="{StaticResource MutedTextBrush}" />
                                                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Id, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBlock Text="Titel" Grid.Row="1" Grid.Column="2" Foreground="{StaticResource MutedTextBrush}" />
                                                        <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                                                        <TextBlock Text="Randomizer" Grid.Row="2" Grid.Column="0" Foreground="{StaticResource MutedTextBrush}" />
                                                        <CheckBox Grid.Row="2" Grid.Column="1" Content="In Randomizer" IsChecked="{Binding IncludeInRandomizer}" />
                                                        <TextBlock Text="alle Minuten" Grid.Row="2" Grid.Column="2" Foreground="{StaticResource MutedTextBrush}" />
                                                        <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding RandomizerEveryMinutes, UpdateSourceTrigger=PropertyChanged}" />

                                                        <TextBlock Text="Event-Gruppe" Grid.Row="3" Grid.Column="0" Foreground="{StaticResource MutedTextBrush}" />
                                                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding EventGroup, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBlock Text="Cooldown Min." Grid.Row="3" Grid.Column="2" Foreground="{StaticResource MutedTextBrush}" />
                                                        <TextBox Grid.Row="3" Grid.Column="3" Text="{Binding CooldownMinutes, UpdateSourceTrigger=PropertyChanged}" />

                                                        <TextBlock Text="Cleanup leer Sek." Grid.Row="4" Grid.Column="0" Foreground="{StaticResource MutedTextBrush}" />
                                                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding CleanupWhenEmptySeconds, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBlock Text="Init Repeat Min." Grid.Row="4" Grid.Column="2" Foreground="{StaticResource MutedTextBrush}" />
                                                        <TextBox Grid.Row="4" Grid.Column="3" Text="{Binding InitiatorRepeatEveryMinutes, UpdateSourceTrigger=PropertyChanged}" />
                                                    </Grid>
                                                </Expander>

                                                <Expander Header="Aktivierungszone / Karte" IsExpanded="True" Style="{StaticResource RedExpander}">
                                                    <StackPanel Margin="0,10,0,0">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="130" /><ColumnDefinition Width="*" /><ColumnDefinition Width="80" /><ColumnDefinition Width="*" /><ColumnDefinition Width="80" /><ColumnDefinition Width="*" /><ColumnDefinition Width="80" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                            <TextBlock Text="Name" Grid.Column="0" Foreground="{StaticResource MutedTextBrush}" />
                                                            <TextBox Text="{Binding ZoneName, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" />
                                                            <TextBlock Text="X" Grid.Column="2" Foreground="{StaticResource MutedTextBrush}" />
                                                            <TextBox Text="{Binding ZoneX, UpdateSourceTrigger=PropertyChanged}" Grid.Column="3" />
                                                            <TextBlock Text="Y" Grid.Column="4" Foreground="{StaticResource MutedTextBrush}" />
                                                            <TextBox Text="{Binding ZoneY, UpdateSourceTrigger=PropertyChanged}" Grid.Column="5" />
                                                            <TextBlock Text="Radius" Grid.Column="6" Foreground="{StaticResource MutedTextBrush}" />
                                                            <TextBox Text="{Binding ZoneRadius, UpdateSourceTrigger=PropertyChanged}" Grid.Column="7" />
                                                        </Grid>
                                                        <Border Margin="0,10,0,0" Height="130" CornerRadius="12" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" Background="#09090D">
                                                            <ItemsControl ItemsSource="{Binding DataContext.ScriptZoneMapItems, RelativeSource={RelativeSource AncestorType=Window}}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Margin="8" Padding="8" CornerRadius="8" Background="#15151D" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1">
                                                                            <StackPanel>
                                                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                                                <TextBlock Text="{Binding Position}" Foreground="{StaticResource MutedTextBrush}" />
                                                                                <TextBlock Text="{Binding Radius, StringFormat=Radius {0:0}}" Foreground="{StaticResource MutedTextBrush}" />
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </Border>
                                                    </StackPanel>
                                                </Expander>

                                                <ItemsControl ItemsSource="{Binding Blocks}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Expander Header="{Binding Name}" IsExpanded="False" Style="{StaticResource RedExpander}">
                                                                <StackPanel Margin="0,10,0,0">
                                                                    <CheckBox Content="Block aktiv" IsChecked="{Binding Enabled}" />
                                                                    <Button Content="+ Command" Width="110" HorizontalAlignment="Left" Command="{Binding DataContext.AddScriptCommandCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                                    <ItemsControl ItemsSource="{Binding Commands}">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Border Margin="0,8,0,0" Padding="10" CornerRadius="10" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" Background="#101016">
                                                                                    <Grid>
                                                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="90" /><ColumnDefinition Width="*" /><ColumnDefinition Width="80" /><ColumnDefinition Width="80" /><ColumnDefinition Width="90" /><ColumnDefinition Width="100" /></Grid.ColumnDefinitions>
                                                                                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                                                                        <CheckBox Grid.Row="0" Grid.Column="0" Content="Aktiv" IsChecked="{Binding Enabled}" />
                                                                                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                                                                        <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding Repeat, UpdateSourceTrigger=PropertyChanged}" />
                                                                                        <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding DelayMs, UpdateSourceTrigger=PropertyChanged}" />
                                                                                        <TextBlock Grid.Row="0" Grid.Column="4" Text="ms Delay" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" />
                                                                                        <Button Grid.Row="0" Grid.Column="5" Content="- Loeschen" Command="{Binding DataContext.RemoveScriptCommandCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                                                        <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="5" Margin="0,8,0,0" IsEditable="True" ItemsSource="{Binding DataContext.ScumCommandSuggestions, RelativeSource={RelativeSource AncestorType=Window}}" Text="{Binding Command, UpdateSourceTrigger=PropertyChanged}" />
                                                                                    </Grid>
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </Expander>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <Expander Header="Liveblock - Loot Spawn" IsExpanded="False" Style="{StaticResource RedExpander}">
                                                    <StackPanel Margin="0,10,0,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="Loot Auswahl" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,10,0" />
                                                            <ComboBox Width="180" ItemsSource="{Binding DataContext.LootSpawnModes, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding LootPackSpawnMode}" />
                                                            <Button Content="+ LootPack" Command="{Binding DataContext.AddLootPackCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                        </StackPanel>
                                                        <ItemsControl ItemsSource="{Binding LootPacks}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Expander Header="{Binding Name}" Style="{StaticResource RedExpander}" IsExpanded="False">
                                                                        <StackPanel Margin="0,8,0,0">
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions><ColumnDefinition Width="80" /><ColumnDefinition Width="*" /><ColumnDefinition Width="80" /><ColumnDefinition Width="100" /><ColumnDefinition Width="100" /></Grid.ColumnDefinitions>
                                                                                <CheckBox Grid.Column="0" Content="Aktiv" IsChecked="{Binding Enabled}" />
                                                                                <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                                                                <TextBox Grid.Column="2" Text="{Binding Weight, UpdateSourceTrigger=PropertyChanged}" />
                                                                                <Button Grid.Column="4" Content="- Pack" Command="{Binding DataContext.RemoveLootPackCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                                            </Grid>
                                                                            <TextBox Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0" ToolTip="Location String" />
                                                                            <Button Content="+ Item" Width="90" HorizontalAlignment="Left" Command="{Binding DataContext.AddLootItemCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                                            <ItemsControl ItemsSource="{Binding Items}">
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate>
                                                                                        <Grid Margin="0,6,0,0">
                                                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="90" /><ColumnDefinition Width="90" /><ColumnDefinition Width="100" /></Grid.ColumnDefinitions>
                                                                                            <ComboBox Grid.Column="0" IsEditable="True" ItemsSource="{Binding DataContext.ScumCommandSuggestions, RelativeSource={RelativeSource AncestorType=Window}}" Text="{Binding Item, UpdateSourceTrigger=PropertyChanged}" />
                                                                                            <TextBox Grid.Column="1" Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" />
                                                                                            <TextBox Grid.Column="2" Text="{Binding DelayMs, UpdateSourceTrigger=PropertyChanged}" />
                                                                                            <Button Grid.Column="3" Content="- Item" Command="{Binding DataContext.RemoveLootItemCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                                                        </Grid>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </StackPanel>
                                                                    </Expander>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Expander>

                                                <Expander Header="Liveblock - NPC Spawn / komplette Loot Commands" IsExpanded="False" Style="{StaticResource RedExpander}">
                                                    <StackPanel Margin="0,10,0,0">
                                                        <Button Content="+ NPC/Loot CommandPack" Width="170" HorizontalAlignment="Left" Command="{Binding DataContext.AddLootCommandPackCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                        <ItemsControl ItemsSource="{Binding LootCommandPacks}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Margin="0,8,0,0" Padding="10" CornerRadius="10" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" Background="#101016">
                                                                        <StackPanel>
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions><ColumnDefinition Width="80" /><ColumnDefinition Width="*" /><ColumnDefinition Width="80" /><ColumnDefinition Width="90" /><ColumnDefinition Width="110" /></Grid.ColumnDefinitions>
                                                                                <CheckBox Grid.Column="0" Content="Aktiv" IsChecked="{Binding Enabled}" />
                                                                                <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                                                                <TextBox Grid.Column="2" Text="{Binding Weight, UpdateSourceTrigger=PropertyChanged}" />
                                                                                <TextBox Grid.Column="3" Text="{Binding DelayMs, UpdateSourceTrigger=PropertyChanged}" />
                                                                                <Button Grid.Column="4" Content="- Loeschen" Command="{Binding DataContext.RemoveLootCommandPackCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                                            </Grid>
                                                                            <ComboBox Margin="0,8,0,0" IsEditable="True" ItemsSource="{Binding DataContext.ScumCommandSuggestions, RelativeSource={RelativeSource AncestorType=Window}}" Text="{Binding Command, UpdateSourceTrigger=PropertyChanged}" />
                                                                            <TextBox Margin="0,8,0,0" Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}" ToolTip="Optionale Location, falls im Command keine Location steht" />
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Expander>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </TabItem>
                                    <TabItem Header="Roh-JSON">
                                        <avalon:TextEditor x:Name="ScriptEditor"
                                                           FontFamily="Consolas"
                                                           FontSize="14"
                                                           ShowLineNumbers="True"
                                                           SyntaxHighlighting="JavaScript"
                                                           Background="#101016"
                                                           Foreground="#F2F2F2"
                                                           LineNumbersForeground="#888888"
                                                           HorizontalScrollBarVisibility="Auto"
                                                           VerticalScrollBarVisibility="Auto" />
                                    </TabItem>
                                </TabControl>
                            </DockPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Debug Logs">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Debug Logs" FontSize="34" FontWeight="Bold" />
                                <TextBlock Text="Hier siehst du, was das Tool gerade macht: RCON-Verbindungen, gesendete Befehle, Discord-Bridge, Chatlog-Scans, Script-Engine und Fehler." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,12" />
                                <TextBlock Text="Logdatei" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBox Text="{Binding LogFilePath, Mode=OneWay}" IsReadOnly="True" />
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button Content="Log-Ordner öffnen" Command="{Binding OpenLogFolderCommand}" />
                                    <Button Content="Anzeige + Datei leeren" Command="{Binding ClearLogCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,14,0,0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Live Log" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <ListBox ItemsSource="{Binding LogLines}" Background="#0D0D12" Foreground="{StaticResource AppTextBrush}" BorderBrush="{StaticResource AppBorderBrush}" FontFamily="Consolas" FontSize="13" />
                            </DockPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Settings">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Settings" FontSize="34" FontWeight="Bold" Margin="0,0,0,18" />
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="RCON" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="Host" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.Host, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Port" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.Port, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Passwort" Foreground="{StaticResource MutedTextBrush}" />
                                    <PasswordBox x:Name="RconPasswordBox" PasswordChanged="RconPasswordBox_PasswordChanged" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="SFTP Logs" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="SFTP Host" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.FtpHost, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="SFTP Port" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.FtpPort, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="SFTP User" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.FtpUser, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="SFTP Passwort" Foreground="{StaticResource MutedTextBrush}" />
                                    <PasswordBox x:Name="SftpPasswordBox" PasswordChanged="SftpPasswordBox_PasswordChanged" />
                                    <TextBlock Text="Remote Directory" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.FtpRemoteDirectory, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Chatlog Pattern" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.FtpChatLogPattern, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Loginlog Pattern" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.FtpLoginLogPattern, UpdateSourceTrigger=PropertyChanged}" />
                                    <CheckBox Content="Scripts automatisch starten" IsChecked="{Binding Settings.AutoStartScripts}" />
                                    <CheckBox Content="Discord Chatlogs automatisch starten" IsChecked="{Binding Settings.AutoStartDiscordChatLogs}" />
                                    <CheckBox Content="Discord Status automatisch starten" IsChecked="{Binding Settings.AutoStartDiscordStatus}" />
                                    <CheckBox Content="Discord Playerlist automatisch aktualisieren" IsChecked="{Binding Settings.AutoStartDiscordPlayerList}" />
                                    <CheckBox Content="Aktive Random Events im Playerlist-Channel anzeigen" IsChecked="{Binding Settings.AutoStartDiscordRandomEvents}" />
                                    <CheckBox Content="Chat Commands automatisch starten" IsChecked="{Binding Settings.AutoStartChatCommands}" />
                                    <CheckBox Content="Join Commands automatisch starten" IsChecked="{Binding Settings.AutoStartJoinCommands}" />
                                    <CheckBox Content="Killfeed automatisch starten" IsChecked="{Binding Settings.AutoStartKillFeed}" />
                                    <CheckBox Content="Weekly Tasks automatisch starten" IsChecked="{Binding Settings.AutoStartWeeklyTasks}" />
                                    <TextBlock Text="Weekly SCUM.db Remote-Dateipfad absolut" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.WeeklyTaskDbRemoteFilePath, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Weekly Poll Minuten" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.WeeklyTaskPollMinutes, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Killlog Pattern" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.FtpKillLogPattern, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Killfeed Poll Sekunden" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.KillPollSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Killfeed Broadcast Farbe" Foreground="{StaticResource MutedTextBrush}" />
                                    <ComboBox ItemsSource="{Binding BroadcastMessageTypes}" SelectedItem="{Binding Settings.KillAnnounceColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Script Poll Sekunden" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.ScriptPollSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                    <CheckBox Content="Random Quests nach Restart-Zeitplan starten" IsChecked="{Binding Settings.RandomQuestScheduledMode}" />
                                    <TextBlock Text="Random Restart-Zeiten lokal (z.B. 04:00,10:00,16:00,22:00)" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.RandomQuestRestartTimes, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Random Quest Intervall Minuten" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.RandomQuestIntervalMinutes, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Random Quest Startverzögerung nach Restart Minuten" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.RandomQuestStartDelayMinutes, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Content="Speichern" Command="{Binding SaveSettingsCommand}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
