                                                                                    <DataTrigger Binding="{Binding Kind}" Value="Trigger">
                                                                                        <Setter Property="BorderBrush" Value="#C1B85C" />
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Kind}" Value="Spawn">
                                                                                        <Setter Property="BorderBrush" Value="#D3152A" />
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Kind}" Value="Loot">
                                                                                        <Setter Property="BorderBrush" Value="#3E9F78" />
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Kind}" Value="Random">
                                                                                        <Setter Property="BorderBrush" Value="#C1B85C" />
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Kind}" Value="LootPack">
                                                                                        <Setter Property="BorderBrush" Value="#3E9F78" />
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Kind}" Value="Command">
                                                                                        <Setter Property="BorderBrush" Value="#5B8FD8" />
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                                        <Setter Property="Background" Value="#241117" />
                                                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                                                        <Setter Property="BorderThickness" Value="2" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <StackPanel>
                                                                            <DockPanel>
                                                                                <TextBlock Text="{Binding Kind}" Foreground="{StaticResource MutedTextBrush}" DockPanel.Dock="Left" />
                                                                                <TextBlock Text=">" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Right" />
                                                                            </DockPanel>
                                                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                                            <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis" />
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Canvas>
                                                </ScrollViewer>
                                            </Border>

                                            <GridSplitter Grid.Column="3" Width="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{StaticResource AppBorderBrush}" />

                                            <Border Grid.Column="4" Background="#101016" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="8,0,0,0">
                                                <DockPanel>
                                                    <StackPanel DockPanel.Dock="Top">
                                                        <TextBlock Text="{Binding SelectedFlowTitle}" FontSize="20" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding SelectedFlowSubtitle}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,12" />
                                                    </StackPanel>
                                                    <ContentControl Content="{Binding SelectedFlowTarget}" />
                                                </DockPanel>
                                            </Border>
                                        </Grid>
                                    </TabItem>

                                    <TabItem Header="Variablen">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel DataContext="{Binding ScriptEditorModel}">
                                                <Expander Header="Triggerzone" IsExpanded="True" Style="{StaticResource RedExpander}">
                                                    <Grid Margin="0,10,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="120" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="90" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Foreground="{StaticResource MutedTextBrush}" />
                                                        <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding ZoneName, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="X" Foreground="{StaticResource MutedTextBrush}" />
                                                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ZoneX, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Y" Foreground="{StaticResource MutedTextBrush}" />
                                                        <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding ZoneY, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Z" Foreground="{StaticResource MutedTextBrush}" />
                                                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ZoneZ, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Radius" Foreground="{StaticResource MutedTextBrush}" />
                                                        <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding ZoneRadius, UpdateSourceTrigger=PropertyChanged}" />
                                                    </Grid>
                                                </Expander>

                                                <Expander Header="Initiatornachricht" IsExpanded="True" Style="{StaticResource RedExpander}">
                                                    <StackPanel Margin="0,10,0,0">
                                                        <TextBox Text="{Binding InitiatorMessage, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" MinHeight="60" TextWrapping="Wrap" />
                                                        <TextBlock Text="Platzhalter: {initiatorMessage}" Foreground="{StaticResource MutedTextBrush}" />
                                                    </StackPanel>
                                                </Expander>

                                                <Expander Header="Lootspawn Koordinaten" IsExpanded="True" Style="{StaticResource RedExpander}">
                                                    <StackPanel Margin="0,10,0,0">
                                                        <Button Content="{Binding DataContext.Texts[AddLootCoordinate], RelativeSource={RelativeSource AncestorType=Window}}" HorizontalAlignment="Left" Command="{Binding DataContext.AddLootLocationVariableCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                        <ItemsControl ItemsSource="{Binding LootSpawnLocations}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Margin="0,8,0,0" Padding="10" CornerRadius="8" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" Background="#101016">
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="170" />
                                                                                <ColumnDefinition Width="*" />
                                                                                <ColumnDefinition Width="170" />
                                                                                <ColumnDefinition Width="100" />
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBox Grid.Column="0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" ToolTip="Variablenname" />
                                                                            <TextBox Grid.Column="1" Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}" ToolTip="SCUM Location" />
                                                                            <TextBox Grid.Column="2" Text="{Binding Placeholder, Mode=OneWay}" IsReadOnly="True" />
                                                                            <Button Grid.Column="3" Content="{Binding DataContext.Texts[Remove], RelativeSource={RelativeSource AncestorType=Window}}" Command="{Binding DataContext.RemoveLocationVariableCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Expander>

                                                <Expander Header="NPCSpawn Koordinaten" IsExpanded="True" Style="{StaticResource RedExpander}">
                                                    <StackPanel Margin="0,10,0,0">
                                                        <Button Content="{Binding DataContext.Texts[AddNpcCoordinate], RelativeSource={RelativeSource AncestorType=Window}}" HorizontalAlignment="Left" Command="{Binding DataContext.AddNpcLocationVariableCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                        <ItemsControl ItemsSource="{Binding NpcSpawnLocations}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Margin="0,8,0,0" Padding="10" CornerRadius="8" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" Background="#101016">
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="170" />
                                                                                <ColumnDefinition Width="*" />
                                                                                <ColumnDefinition Width="170" />
                                                                                <ColumnDefinition Width="100" />
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBox Grid.Column="0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" ToolTip="Variablenname" />
                                                                            <TextBox Grid.Column="1" Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}" ToolTip="SCUM Location" />
                                                                            <TextBox Grid.Column="2" Text="{Binding Placeholder, Mode=OneWay}" IsReadOnly="True" />
                                                                            <Button Grid.Column="3" Content="{Binding DataContext.Texts[Remove], RelativeSource={RelativeSource AncestorType=Window}}" Command="{Binding DataContext.RemoveLocationVariableCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Expander>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </TabItem>

                                    <TabItem Header="Ablauf" Visibility="Collapsed">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel DataContext="{Binding ScriptEditorModel}">
                                                <Expander Header="Titel / Main Einstellungen" IsExpanded="True" Style="{StaticResource RedExpander}">
                                                    <Grid Margin="0,10,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="150" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="150" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Text="Aktiv" Grid.Row="0" Grid.Column="0" Foreground="{StaticResource MutedTextBrush}" />
                                                        <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding Enabled}" />
                                                        <TextBlock Text="Modus" Grid.Row="0" Grid.Column="2" Foreground="{StaticResource MutedTextBrush}" />
                                                        <ComboBox Grid.Row="0" Grid.Column="3" ItemsSource="{Binding DataContext.ScriptModes, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding Mode}" />

                                                        <TextBlock Text="ID" Grid.Row="1" Grid.Column="0" Foreground="{StaticResource MutedTextBrush}" />
                                                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Id, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBlock Text="Titel" Grid.Row="1" Grid.Column="2" Foreground="{StaticResource MutedTextBrush}" />
                                                        <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                                                        <TextBlock Text="Randomizer" Grid.Row="2" Grid.Column="0" Foreground="{StaticResource MutedTextBrush}" />
                                                        <CheckBox Grid.Row="2" Grid.Column="1" Content="In Randomizer" IsChecked="{Binding IncludeInRandomizer}" />
                                                        <TextBlock Text="alle Minuten" Grid.Row="2" Grid.Column="2" Foreground="{StaticResource MutedTextBrush}" />
                                                        <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding RandomizerEveryMinutes, UpdateSourceTrigger=PropertyChanged}" />

                                                        <TextBlock Text="Event-Gruppe" Grid.Row="3" Grid.Column="0" Foreground="{StaticResource MutedTextBrush}" />
                                                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding EventGroup, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBlock Text="Cooldown Min." Grid.Row="3" Grid.Column="2" Foreground="{StaticResource MutedTextBrush}" />
                                                        <TextBox Grid.Row="3" Grid.Column="3" Text="{Binding CooldownMinutes, UpdateSourceTrigger=PropertyChanged}" />

                                                        <TextBlock Text="Cleanup leer Sek." Grid.Row="4" Grid.Column="0" Foreground="{StaticResource MutedTextBrush}" />
                                                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding CleanupWhenEmptySeconds, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBlock Text="Init Repeat Min." Grid.Row="4" Grid.Column="2" Foreground="{StaticResource MutedTextBrush}" />
                                                        <TextBox Grid.Row="4" Grid.Column="3" Text="{Binding InitiatorRepeatEveryMinutes, UpdateSourceTrigger=PropertyChanged}" />
                                                    </Grid>
                                                </Expander>

                                                <Expander Header="Aktivierungszone / Karte" IsExpanded="True" Style="{StaticResource RedExpander}">
                                                    <StackPanel Margin="0,10,0,0">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="130" /><ColumnDefinition Width="*" /><ColumnDefinition Width="80" /><ColumnDefinition Width="*" /><ColumnDefinition Width="80" /><ColumnDefinition Width="*" /><ColumnDefinition Width="80" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                            <TextBlock Text="Name" Grid.Column="0" Foreground="{StaticResource MutedTextBrush}" />
                                                            <TextBox Text="{Binding ZoneName, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" />
                                                            <TextBlock Text="X" Grid.Column="2" Foreground="{StaticResource MutedTextBrush}" />
                                                            <TextBox Text="{Binding ZoneX, UpdateSourceTrigger=PropertyChanged}" Grid.Column="3" />
                                                            <TextBlock Text="Y" Grid.Column="4" Foreground="{StaticResource MutedTextBrush}" />
                                                            <TextBox Text="{Binding ZoneY, UpdateSourceTrigger=PropertyChanged}" Grid.Column="5" />
                                                            <TextBlock Text="Radius" Grid.Column="6" Foreground="{StaticResource MutedTextBrush}" />
                                                            <TextBox Text="{Binding ZoneRadius, UpdateSourceTrigger=PropertyChanged}" Grid.Column="7" />
                                                        </Grid>
                                                        <Border Margin="0,10,0,0" Height="130" CornerRadius="12" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" Background="#09090D">
                                                            <ItemsControl ItemsSource="{Binding DataContext.ScriptZoneMapItems, RelativeSource={RelativeSource AncestorType=Window}}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Margin="8" Padding="8" CornerRadius="8" Background="#15151D" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1">
                                                                            <StackPanel>
                                                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                                                <TextBlock Text="{Binding Position}" Foreground="{StaticResource MutedTextBrush}" />
                                                                                <TextBlock Text="{Binding Radius, StringFormat=Radius {0:0}}" Foreground="{StaticResource MutedTextBrush}" />
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </Border>
                                                    </StackPanel>
                                                </Expander>

                                                <ItemsControl ItemsSource="{Binding Blocks}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Expander Header="{Binding Name}" IsExpanded="False" Style="{StaticResource RedExpander}">
                                                                <StackPanel Margin="0,10,0,0">
                                                                    <CheckBox Content="Block aktiv" IsChecked="{Binding Enabled}" />
                                                                    <Button Content="{Binding DataContext.Texts[AddCommand], RelativeSource={RelativeSource AncestorType=Window}}" Width="110" HorizontalAlignment="Left" Command="{Binding DataContext.AddScriptCommandCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                                    <ItemsControl ItemsSource="{Binding Commands}">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Border Margin="0,8,0,0" Padding="10" CornerRadius="10" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" Background="#101016">
                                                                                    <Grid>
                                                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="90" /><ColumnDefinition Width="*" /><ColumnDefinition Width="80" /><ColumnDefinition Width="80" /><ColumnDefinition Width="90" /><ColumnDefinition Width="100" /></Grid.ColumnDefinitions>
                                                                                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                                                                        <CheckBox Grid.Row="0" Grid.Column="0" Content="Aktiv" IsChecked="{Binding Enabled}" />
                                                                                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                                                                        <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding Repeat, UpdateSourceTrigger=PropertyChanged}" />
                                                                                        <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding DelayMs, UpdateSourceTrigger=PropertyChanged}" />
                                                                                        <TextBlock Grid.Row="0" Grid.Column="4" Text="ms Delay" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" />
                                                                                        <Button Grid.Row="0" Grid.Column="5" Content="{Binding DataContext.Texts[RemoveDelete], RelativeSource={RelativeSource AncestorType=Window}}" Command="{Binding DataContext.RemoveScriptCommandCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                                                        <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="5" Margin="0,8,0,0" IsEditable="True" ItemsSource="{Binding DataContext.ScumCommandSuggestions, RelativeSource={RelativeSource AncestorType=Window}}" Text="{Binding Command, UpdateSourceTrigger=PropertyChanged}" />
                                                                                    </Grid>
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </Expander>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <Expander Header="Liveblock - Spawn Bausteine" IsExpanded="True" Style="{StaticResource RedExpander}">
                                                    <StackPanel Margin="0,10,0,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Button Content="{Binding DataContext.Texts[AddSpawn], RelativeSource={RelativeSource AncestorType=Window}}" Command="{Binding DataContext.AddSpawnBlockCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                        </StackPanel>
                                                        <ItemsControl ItemsSource="{Binding SpawnBlocks}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Margin="0,8,0,0" Padding="10" CornerRadius="10" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" Background="#101016">
                                                                        <StackPanel>
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="78" />
                                                                                    <ColumnDefinition Width="*" />
                                                                                    <ColumnDefinition Width="105" />
                                                                                    <ColumnDefinition Width="150" />
                                                                                    <ColumnDefinition Width="90" />
                                                                                    <ColumnDefinition Width="90" />
                                                                                    <ColumnDefinition Width="105" />
                                                                                </Grid.ColumnDefinitions>
                                                                                <CheckBox Grid.Column="0" Content="Aktiv" IsChecked="{Binding Enabled}" />
                                                                                <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" ToolTip="Name des Bausteins" />
                                                                                <ComboBox Grid.Column="2" ItemsSource="{Binding DataContext.SpawnBlockTypes, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding Type}" />
                                                                                <TextBox Grid.Column="3" Text="{Binding Asset, UpdateSourceTrigger=PropertyChanged}" ToolTip="Item, NPC Blueprint oder Vehicle Blueprint" />
                                                                                <TextBox Grid.Column="4" Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" ToolTip="Menge" />
                                                                                <TextBox Grid.Column="5" Text="{Binding DelayMs, UpdateSourceTrigger=PropertyChanged}" ToolTip="Delay nach dem RCON-Befehl in Millisekunden" />
                                                                                <Button Grid.Column="6" Content="{Binding DataContext.Texts[RemoveDelete], RelativeSource={RelativeSource AncestorType=Window}}" Command="{Binding DataContext.RemoveSpawnBlockCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                                            </Grid>
                                                                            <TextBox Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0" ToolTip="SCUM Location, z. B. [{X=... Y=... Z=...|P=... Y=... R=...}]" />
                                                                            <Grid Margin="0,4,0,0">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="130" />
                                                                                    <ColumnDefinition Width="110" />
                                                                                    <ColumnDefinition Width="110" />
                                                                                    <ColumnDefinition Width="110" />
                                                                                    <ColumnDefinition Width="130" />
                                                                                    <ColumnDefinition Width="*" />
                                                                                </Grid.ColumnDefinitions>
                                                                                <TextBox Grid.Column="0" Text="{Binding DespawnLifetimeSeconds, UpdateSourceTrigger=PropertyChanged}" ToolTip="DespawnLifetime in Sekunden, 0 = nicht anhaengen" />
                                                                                <TextBox Grid.Column="1" Text="{Binding StartDelaySeconds, UpdateSourceTrigger=PropertyChanged}" ToolTip="Startdelay in Sekunden" />
                                                                                <TextBox Grid.Column="2" Text="{Binding Repeat, UpdateSourceTrigger=PropertyChanged}" ToolTip="Anzahl Spawn-Durchlaeufe" />
                                                                                <TextBox Grid.Column="3" Text="{Binding RepeatEverySeconds, UpdateSourceTrigger=PropertyChanged}" ToolTip="Sekunden zwischen Wiederholungen" />
                                                                                <CheckBox Grid.Column="4" Content="ExecAs Spieler" IsChecked="{Binding UseTriggerPlayer}" VerticalAlignment="Center" />
                                                                                <TextBox Grid.Column="5" Text="{Binding Extra, UpdateSourceTrigger=PropertyChanged}" ToolTip="Optionaler Zusatz, z. B. Modifier minimalfunctional" />
                                                                            </Grid>
                                                                            <Grid Margin="0,0,0,2">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="130" />
                                                                                    <ColumnDefinition Width="110" />
                                                                                    <ColumnDefinition Width="110" />
                                                                                    <ColumnDefinition Width="110" />
                                                                                    <ColumnDefinition Width="130" />
                                                                                    <ColumnDefinition Width="*" />
                                                                                </Grid.ColumnDefinitions>
                                                                                <TextBlock Grid.Column="0" Text="Despawn Sek." Foreground="{StaticResource MutedTextBrush}" />
                                                                                <TextBlock Grid.Column="1" Text="Start Sek." Foreground="{StaticResource MutedTextBrush}" />
                                                                                <TextBlock Grid.Column="2" Text="Repeat" Foreground="{StaticResource MutedTextBrush}" />
                                                                                <TextBlock Grid.Column="3" Text="Loop Sek." Foreground="{StaticResource MutedTextBrush}" />
                                                                                <TextBlock Grid.Column="5" Text="Extra" Foreground="{StaticResource MutedTextBrush}" />
                                                                            </Grid>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Expander>

                                                <Expander Header="Liveblock - Loot Spawn" IsExpanded="False" Style="{StaticResource RedExpander}">
                                                    <StackPanel Margin="0,10,0,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="Loot Auswahl" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,10,0" />
                                                            <ComboBox Width="180" ItemsSource="{Binding DataContext.LootSpawnModes, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding LootPackSpawnMode}" />
                                                            <Button Content="{Binding DataContext.Texts[AddLootPack], RelativeSource={RelativeSource AncestorType=Window}}" Command="{Binding DataContext.AddLootPackCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                        </StackPanel>
                                                        <ItemsControl ItemsSource="{Binding LootPacks}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Expander Header="{Binding Name}" Style="{StaticResource RedExpander}" IsExpanded="False">
                                                                        <StackPanel Margin="0,8,0,0">
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions><ColumnDefinition Width="80" /><ColumnDefinition Width="*" /><ColumnDefinition Width="80" /><ColumnDefinition Width="100" /><ColumnDefinition Width="100" /></Grid.ColumnDefinitions>
                                                                                <CheckBox Grid.Column="0" Content="Aktiv" IsChecked="{Binding Enabled}" />
                                                                                <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                                                                <TextBox Grid.Column="2" Text="{Binding Weight, UpdateSourceTrigger=PropertyChanged}" />
                                                                                <Button Grid.Column="4" Content="{Binding DataContext.Texts[RemovePack], RelativeSource={RelativeSource AncestorType=Window}}" Command="{Binding DataContext.RemoveLootPackCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                                            </Grid>
                                                                            <TextBox Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0" ToolTip="Location String" />
                                                                            <Button Content="{Binding DataContext.Texts[AddItem], RelativeSource={RelativeSource AncestorType=Window}}" Width="90" HorizontalAlignment="Left" Command="{Binding DataContext.AddLootItemCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                                            <ItemsControl ItemsSource="{Binding Items}">
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate>
                                                                                        <Grid Margin="0,6,0,0">
                                                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="90" /><ColumnDefinition Width="90" /><ColumnDefinition Width="100" /></Grid.ColumnDefinitions>
                                                                                            <ComboBox Grid.Column="0" IsEditable="True" ItemsSource="{Binding DataContext.ScumCommandSuggestions, RelativeSource={RelativeSource AncestorType=Window}}" Text="{Binding Item, UpdateSourceTrigger=PropertyChanged}" />
                                                                                            <TextBox Grid.Column="1" Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" />
                                                                                            <TextBox Grid.Column="2" Text="{Binding DelayMs, UpdateSourceTrigger=PropertyChanged}" />
                                                                                            <Button Grid.Column="3" Content="{Binding DataContext.Texts[RemoveItem], RelativeSource={RelativeSource AncestorType=Window}}" Command="{Binding DataContext.RemoveLootItemCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                                                        </Grid>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </StackPanel>
                                                                    </Expander>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Expander>

                                                <Expander Header="Liveblock - NPC Spawn / komplette Loot Commands" IsExpanded="False" Style="{StaticResource RedExpander}">
                                                    <StackPanel Margin="0,10,0,0">
                                                        <Button Content="{Binding DataContext.Texts[AddNpcLootCommandPack], RelativeSource={RelativeSource AncestorType=Window}}" Width="170" HorizontalAlignment="Left" Command="{Binding DataContext.AddLootCommandPackCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                        <ItemsControl ItemsSource="{Binding LootCommandPacks}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Margin="0,8,0,0" Padding="10" CornerRadius="10" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" Background="#101016">
                                                                        <StackPanel>
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions><ColumnDefinition Width="80" /><ColumnDefinition Width="*" /><ColumnDefinition Width="80" /><ColumnDefinition Width="90" /><ColumnDefinition Width="110" /></Grid.ColumnDefinitions>
                                                                                <CheckBox Grid.Column="0" Content="Aktiv" IsChecked="{Binding Enabled}" />
                                                                                <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                                                                <TextBox Grid.Column="2" Text="{Binding Weight, UpdateSourceTrigger=PropertyChanged}" />
                                                                                <TextBox Grid.Column="3" Text="{Binding DelayMs, UpdateSourceTrigger=PropertyChanged}" />
                                                                                <Button Grid.Column="4" Content="{Binding DataContext.Texts[RemoveDelete], RelativeSource={RelativeSource AncestorType=Window}}" Command="{Binding DataContext.RemoveLootCommandPackCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                                            </Grid>
                                                                            <ComboBox Margin="0,8,0,0" IsEditable="True" ItemsSource="{Binding DataContext.ScumCommandSuggestions, RelativeSource={RelativeSource AncestorType=Window}}" Text="{Binding Command, UpdateSourceTrigger=PropertyChanged}" />
                                                                            <TextBox Margin="0,8,0,0" Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}" ToolTip="Optionale Location, falls im Command keine Location steht" />
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Expander>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </TabItem>
                                    <TabItem Header="Roh-JSON">
                                        <avalon:TextEditor x:Name="ScriptEditor"
                                                           FontFamily="Consolas"
                                                           FontSize="14"
                                                           ShowLineNumbers="True"
                                                           SyntaxHighlighting="JavaScript"
                                                           Background="#101016"
                                                           Foreground="#F2F2F2"
                                                           LineNumbersForeground="#888888"
                                                           HorizontalScrollBarVisibility="Auto"
                                                           VerticalScrollBarVisibility="Auto" />
                                    </TabItem>
                                </TabControl>
                            </DockPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Debug Logs">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Debug Logs" FontSize="34" FontWeight="Bold" />
                                <TextBlock Text="Hier siehst du, was das Tool gerade macht: RCON-Verbindungen, gesendete Befehle, Discord-Bridge, Chatlog-Scans, Script-Engine und Fehler." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,12" />
                                <TextBlock Text="Logdatei" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBox Text="{Binding LogFilePath, Mode=OneWay}" IsReadOnly="True" />
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button Content="{Binding Texts[OpenLogFolder]}" Command="{Binding OpenLogFolderCommand}" />
                                    <Button Content="{Binding Texts[ClearLogDisplayAndFile]}" Command="{Binding ClearLogCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,14,0,0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Live Log" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <ListBox ItemsSource="{Binding LogLines}" Background="#0D0D12" Foreground="{StaticResource AppTextBrush}" BorderBrush="{StaticResource AppBorderBrush}" FontFamily="Consolas" FontSize="13" />
                            </DockPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Settings">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Settings" FontSize="34" FontWeight="Bold" Margin="0,0,0,18" />
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="RCON" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="Host" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.Host, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Port" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.Port, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Passwort" Foreground="{StaticResource MutedTextBrush}" />
                                    <PasswordBox x:Name="RconPasswordBox" PasswordChanged="RconPasswordBox_PasswordChanged" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="SFTP Logs" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="SFTP Host" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.FtpHost, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="SFTP Port" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.FtpPort, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="SFTP User" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.FtpUser, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="SFTP Passwort" Foreground="{StaticResource MutedTextBrush}" />
                                    <PasswordBox x:Name="SftpPasswordBox" PasswordChanged="SftpPasswordBox_PasswordChanged" />
                                    <TextBlock Text="Remote Directory" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.FtpRemoteDirectory, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Chatlog Pattern" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.FtpChatLogPattern, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Vehicle-Destruction Log Pattern" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.FtpVehicleDestructionLogPattern, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Loginlog Pattern" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.FtpLoginLogPattern, UpdateSourceTrigger=PropertyChanged}" />
                                    <CheckBox Content="Scripts automatisch starten" IsChecked="{Binding Settings.AutoStartScripts}" />
                                    <CheckBox Content="Discord Chatlogs automatisch starten" IsChecked="{Binding Settings.AutoStartDiscordChatLogs}" />
                                    <CheckBox Content="Discord Serverstatus-Nachricht automatisch aktualisieren" IsChecked="{Binding Settings.AutoStartDiscordServerStatusMessage}" />
                                    <CheckBox Content="Discord Botstatus automatisch aktualisieren" IsChecked="{Binding Settings.AutoStartDiscordBotStatus}" />
                                    <CheckBox Content="Updates beim Start pruefen" IsChecked="{Binding Settings.AutoCheckForUpdates}" />
                                    <TextBlock Text="Update latest.json URL" Foreground="{StaticResource MutedTextBrush}" Margin="0,10,0,0" />
                                    <TextBox Text="{Binding Settings.UpdateLatestJsonUrl, UpdateSourceTrigger=PropertyChanged}" />
                                    <CheckBox Content="Chat Commands automatisch starten" IsChecked="{Binding Settings.AutoStartChatCommands}" />
                                    <CheckBox Content="Chat Commands via ggCON HTTP Logs lesen" IsChecked="{Binding Settings.UseGgconLogsForChatCommands}" />
                                    <TextBlock Text="ggCON Chat Command Poll Sekunden" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.GgconChatCommandPollSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="ggCON Chat Initial Backfill Sekunden" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.GgconChatCommandInitialBackfillSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                    <CheckBox Content="Votes mit Ingamegeld kaufen" IsChecked="{Binding Settings.PaidVotesEnabled}" />
                                    <TextBlock Text="Vote-Kaufpreis" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.VotePrice, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Vote-Bestaetigung Sekunden" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.VoteConfirmationTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Vote Kauf-Anfrage" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.VotePurchasePromptResponse, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />
                                    <TextBlock Text="Vote Nicht-genug-Geld-Antwort" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.VoteInsufficientFundsResponse, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />
                                    <CheckBox Content="Join Commands automatisch starten" IsChecked="{Binding Settings.AutoStartJoinCommands}" />
                                    <CheckBox Content="Killfeed automatisch starten" IsChecked="{Binding Settings.AutoStartKillFeed}" />
                                    <CheckBox Content="Weekly Tasks automatisch starten" IsChecked="{Binding Settings.AutoStartWeeklyTasks}" />
                                    <TextBlock Text="Weekly SCUM.db Remote-Dateipfad absolut" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.WeeklyTaskDbRemoteFilePath, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Weekly Poll Minuten" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.WeeklyTaskPollMinutes, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Killlog Pattern" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.FtpKillLogPattern, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Killfeed Poll Sekunden" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.KillPollSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Killfeed Broadcast Farbe" Foreground="{StaticResource MutedTextBrush}" />
                                    <ComboBox ItemsSource="{Binding BroadcastMessageTypes}" SelectedItem="{Binding Settings.KillAnnounceColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Script Poll Sekunden" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.ScriptPollSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                    <CheckBox Content="Random Quests nach Restart-Zeitplan starten" IsChecked="{Binding Settings.RandomQuestScheduledMode}" />
                                    <TextBlock Text="Random Restart-Zeiten lokal (z.B. 04:00,10:00,16:00,22:00)" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.RandomQuestRestartTimes, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Random Quest Intervall Minuten" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.RandomQuestIntervalMinutes, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Random Quest Startverzögerung nach Restart Minuten" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBox Text="{Binding Settings.RandomQuestStartDelayMinutes, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Content="{Binding Texts[Save]}" Command="{Binding SaveSettingsCommand}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
